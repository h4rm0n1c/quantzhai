#!/usr/bin/env python3
"""Write QuantZhai runtime truth for status/monitor consumers.

This is intentionally usable from shell startup scripts before the proxy has seen
any model request. It records requested/intended values first, then can merge
proxy/backend facts as they become available.
"""

import argparse
import json
import os
import tempfile
import time
import urllib.request
from pathlib import Path
from typing import Any


SCHEMA = 1


def parse_context(value: Any, default: int | None = None) -> int | None:
    if value is None or isinstance(value, bool):
        return default
    if isinstance(value, int):
        return value
    if isinstance(value, float):
        return int(value)
    text = str(value).strip().lower()
    if not text:
        return default
    multiplier = 1
    if text.endswith("k"):
        multiplier = 1024
        text = text[:-1]
    elif text.endswith("m"):
        multiplier = 1024 * 1024
        text = text[:-1]
    elif text.endswith("g"):
        multiplier = 1024 * 1024 * 1024
        text = text[:-1]
    try:
        return int(float(text) * multiplier)
    except Exception:
        return default


def env_int(name: str, default: int | None = None) -> int | None:
    return parse_context(os.environ.get(name), default)


def runtime_path() -> Path:
    default_var = Path(os.environ.get("QZ_VAR_DIR") or "var")
    return Path(os.environ.get("QZ_RUNTIME_STATE_PATH") or default_var / "run" / "qz-runtime-state.json").expanduser()


def atomic_write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    text = json.dumps(payload, indent=2, ensure_ascii=False, sort_keys=True) + "\n"
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=str(path.parent), delete=False) as handle:
        handle.write(text)
        tmp_name = handle.name
    os.replace(tmp_name, path)


def read_json(path: Path) -> dict[str, Any]:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def fetch_json(url: str, timeout: float = 0.8) -> dict[str, Any]:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as response:
            data = json.loads(response.read().decode("utf-8"))
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def proxy_base_url() -> str:
    host = os.environ.get("QZ_PROXY_HOST", "127.0.0.1")
    port = os.environ.get("QZ_PROXY_PORT", "18180")
    return f"http://{host}:{port}"


def base_state(phase: str, source: str) -> dict[str, Any]:
    context = env_int("QZ_CONTEXT", 131072)
    return {
        "schema": SCHEMA,
        "phase": phase,
        "updated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "updated_ts": time.time(),
        "source": {
            "context": source,
            "model": "env",
            "backend": "env",
        },
        "requested": {
            "profile": os.environ.get("QZ_PROFILE", ""),
            "model": os.environ.get("QZ_MODEL_KEY", ""),
            "context": context,
        },
        "effective": {
            "model": os.environ.get("QZ_MODEL_KEY", ""),
            "context": context,
            "parallel": env_int("QZ_PARALLEL"),
            "batch": env_int("QZ_BATCH"),
            "ubatch": env_int("QZ_UBATCH"),
            "threads": env_int("QZ_THREADS"),
            "thread_batch": env_int("QZ_THREAD_BATCH"),
            "tensor_split": os.environ.get("QZ_TENSOR_SPLIT", ""),
            "main_gpu": os.environ.get("QZ_MAIN_GPU", ""),
            "cache_ram_mib": env_int("QZ_CACHE_RAM"),
            "cache_reuse": env_int("QZ_CACHE_REUSE"),
            "kv_key": os.environ.get("QZ_KV_KEY", ""),
            "kv_value": os.environ.get("QZ_KV_VALUE", ""),
        },
        "backend": {
            "url": f"http://{os.environ.get('QZ_SERVER_HOST', '127.0.0.1')}:{os.environ.get('QZ_SERVER_PORT', '18084')}",
            "healthy": False,
            "loaded": False,
            "loaded_model": "",
            "load_state": "unconfirmed",
            "health_status": None,
        },
        "proxy": {
            "url": proxy_base_url(),
            "healthy": False,
        },
        "notes": [],
    }


def merge_proxy_status(state: dict[str, Any]) -> None:
    status = fetch_json(proxy_base_url() + "/qz/status")
    if not status:
        status = fetch_json(proxy_base_url() + "/qz/telemetry/state")
    if not status:
        return

    state.setdefault("proxy", {})["healthy"] = True
    state["source"]["proxy"] = "proxy"

    runtime = status.get("runtime") if isinstance(status.get("runtime"), dict) else status
    backend = status.get("backend") if isinstance(status.get("backend"), dict) else {}
    load = status.get("load") if isinstance(status.get("load"), dict) else {}

    selected = (
        runtime.get("selected")
        or runtime.get("selected_backend_id")
        or backend.get("selected_backend_id")
        or backend.get("selected_key")
        or ""
    )
    if selected:
        state["effective"]["model"] = selected
        state["source"]["model"] = "proxy"

    context = parse_context(
        runtime.get("backend_context_length")
        or backend.get("backend_context_length")
        or runtime.get("selected_context_length")
        or backend.get("selected_context_length"),
        None,
    )
    if context:
        state["effective"]["context"] = context
        state["source"]["context"] = "proxy"

    loaded = runtime.get("loaded_model") or backend.get("loaded_model") or ""
    loaded_count = runtime.get("loaded_count") or backend.get("loaded_count") or 0
    load_state = runtime.get("load_state") or load.get("state") or backend.get("selected_state") or "unknown"
    health_status = runtime.get("health_status")
    if health_status is None and isinstance(status.get("health"), dict):
        health_status = status["health"].get("status")

    state["backend"].update({
        "healthy": health_status == 200 or bool(runtime.get("ready")) or bool(status.get("ready")),
        "loaded": bool(loaded) or load_state in {"ready", "loaded"},
        "loaded_model": loaded,
        "loaded_count": loaded_count,
        "load_state": load_state,
        "health_status": health_status,
    })


def main() -> int:
    parser = argparse.ArgumentParser(description="write QuantZhai runtime-state snapshot")
    parser.add_argument("--phase", default="manual", help="startup phase label")
    parser.add_argument("--source", default="env", help="source label for requested values")
    parser.add_argument("--merge-proxy", action="store_true", help="merge live proxy status when reachable")
    parser.add_argument("--backend-healthy", action="store_true", help="mark backend health as confirmed")
    parser.add_argument("--proxy-healthy", action="store_true", help="mark proxy health as confirmed")
    parser.add_argument("--print", dest="print_state", action="store_true", help="print written state")
    args = parser.parse_args()

    state = base_state(args.phase, args.source)
    if args.backend_healthy:
        state["backend"]["healthy"] = True
        state["backend"]["health_status"] = 200
        state["source"]["backend"] = "health"
    if args.proxy_healthy:
        state["proxy"]["healthy"] = True
    if args.merge_proxy:
        merge_proxy_status(state)

    path = runtime_path()
    previous = read_json(path)
    if previous and state["effective"].get("model") in (None, ""):
        old_model = ((previous.get("effective") or {}).get("model") or "")
        if old_model:
            state["effective"]["model"] = old_model
            state["source"]["model"] = "previous"
    atomic_write_json(path, state)

    if args.print_state:
        print(json.dumps(state, indent=2, ensure_ascii=False, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
