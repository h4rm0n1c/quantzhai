#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/qz-env"

pid_file="$QZ_VAR_DIR/run/qz-proxy.pid"

if [[ -f "$pid_file" ]]; then
  old_pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
    kill "$old_pid"
  fi
  rm -f "$pid_file"
fi

if qz_docker ps -a --format '{{.Names}}' | grep -qx "$QZ_CONTAINER"; then
  qz_docker rm -f "$QZ_CONTAINER" >/dev/null
fi

echo "QuantZhai stopped."
