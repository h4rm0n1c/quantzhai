#!/usr/bin/env bash

QZ_CODEX_COMMON_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck disable=SC1091
source "$QZ_CODEX_COMMON_DIR/qz-env"

qz_prepare_codex_home() {
  mkdir -p \
    "$QZ_VAR_DIR/codex-home/model-catalogs" \
    "$QZ_VAR_DIR/codex-home/sqlite" \
    "$QZ_VAR_DIR/logs" \
    "$QZ_VAR_DIR/run" \
    "$QZ_VAR_DIR/captures" \
    "$QZ_VAR_DIR/benchmarks"

  if [[ ! -f "$QZ_ROOT/var/codex-home/config.toml" ]]; then
    cp "$QZ_ROOT/config/codex-config.example.toml" "$QZ_ROOT/var/codex-home/config.toml"
  fi

  local catalog_dst="$QZ_ROOT/var/codex-home/model-catalogs/qwenzhai-models.json"
  python3 "$QZ_ROOT/proxy/qz_model_catalog.py" scan >/dev/null 2>&1 || true
  python3 - "$QZ_ROOT/config/qwenzhai-models.example.json" "$QZ_MODEL_INVENTORY_CACHE" "$catalog_dst" "$QZ_ROOT/config/codex-config.example.toml" "$QZ_ROOT/var/codex-home/config.toml" <<'PY'
import json
import re
import sys
from copy import deepcopy
from pathlib import Path

catalog_src = Path(sys.argv[1])
inventory_path = Path(sys.argv[2])
catalog_dst = Path(sys.argv[3])
config_src = Path(sys.argv[4])
config_dst = Path(sys.argv[5])

catalog = json.loads(catalog_src.read_text(encoding="utf-8"))
inventory = json.loads(inventory_path.read_text(encoding="utf-8")) if inventory_path.is_file() else {}
models = [model for model in catalog.get("models", []) if isinstance(model, dict)]
model_by_slug = {model.get("slug"): model for model in models if model.get("slug")}
template = model_by_slug.get("Qwen3.6Turbo-medium") or (models[0] if models else {})

def reasoning_level(entry):
    text = " ".join(
        str(value).lower()
        for value in (
            entry.get("label"),
            entry.get("name"),
            entry.get("notes"),
            entry.get("stem"),
            entry.get("backend_id"),
        )
        if value
    )
    if "apex" in text or "reasoning" in text:
        return "high"
    if "iq4" in text or "aggressive" in text or "fast" in text:
        return "low"
    return "medium"

def build_live_model(entry, priority):
    slug = entry.get("backend_id") or entry.get("stem") or entry.get("filename") or entry.get("key")
    if not slug:
        return None
    model = deepcopy(template)
    model["slug"] = slug
    label = entry.get("label") or entry.get("name") or slug
    model["display_name"] = label
    notes = entry.get("notes") or entry.get("overrides", {}).get("notes")
    model["description"] = notes or f"Local GGUF model: {label}"
    model["default_reasoning_level"] = reasoning_level(entry)
    model["priority"] = entry.get("priority") if entry.get("priority") is not None else priority
    model["context_window"] = entry.get("context_length") or model.get("context_window")
    model["max_context_window"] = entry.get("context_length") or model.get("max_context_window")
    model["supported_in_api"] = True
    model["visibility"] = "list"
    return model

live_models = []
for index, entry in enumerate(inventory.get("models", [])):
    if not isinstance(entry, dict):
        continue
    live_model = build_live_model(entry, 1500 + index)
    if live_model:
        live_models.append(live_model)

catalog["models"] = live_models if live_models else models
catalog_dst.write_text(json.dumps(catalog, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")

example_config = config_src.read_text(encoding="utf-8").rstrip("\n") + "\n"
existing_config = config_dst.read_text(encoding="utf-8") if config_dst.is_file() else ""
tail = ""
if existing_config:
    lines = existing_config.splitlines(keepends=True)
    keep_block = False
    current_block = []
    tail_blocks = []
    for index, line in enumerate(lines):
        if line.startswith("["):
            if current_block:
                header = current_block[0].strip()
                if not header.startswith("[model_providers.") and not header.startswith("[profiles."):
                    tail_blocks.append("".join(current_block))
            current_block = [line]
        elif current_block:
            current_block.append(line)
    if current_block:
        header = current_block[0].strip()
        if not header.startswith("[model_providers.") and not header.startswith("[profiles."):
            tail_blocks.append("".join(current_block))
    tail = "".join(tail_blocks)

merged_config = example_config
if tail:
    merged_config += "\n" + tail.lstrip("\n")

merged_config = re.sub(
    r'(?m)^model_catalog_json\s*=\s*".*"$',
    f'model_catalog_json = "{catalog_dst}"',
    merged_config,
    count=1,
)
if not re.search(r'(?m)^model_catalog_json\s*=', merged_config):
    merged_config = f'model_catalog_json = "{catalog_dst}"\n' + merged_config

config_dst.write_text(merged_config.rstrip("\n") + "\n", encoding="utf-8")
PY

  local tmp_config="$QZ_ROOT/var/codex-home/config.toml.tmp"
  local catalog_line="model_catalog_json = \"$QZ_ROOT/var/codex-home/model-catalogs/qwenzhai-models.json\""
  if grep -q '^model_catalog_json' "$QZ_ROOT/var/codex-home/config.toml"; then
    sed "s|^model_catalog_json = .*|$catalog_line|" "$QZ_ROOT/var/codex-home/config.toml" > "$tmp_config"
  else
    { printf '%s\n' "$catalog_line"; cat "$QZ_ROOT/var/codex-home/config.toml"; } > "$tmp_config"
  fi
  mv "$tmp_config" "$QZ_ROOT/var/codex-home/config.toml"

  export CODEX_HOME="$QZ_ROOT/var/codex-home"
  export CODEX_SQLITE_HOME="$CODEX_HOME/sqlite"
  export CODEX_OSS_BASE_URL="http://$QZ_PROXY_HOST:$QZ_PROXY_PORT"
  export LOCAL_QWEN_API_KEY="${LOCAL_QWEN_API_KEY:-local}"

  QZ_CODEX_MODEL_PROVIDER="${QZ_CODEX_MODEL_PROVIDER:-$(python3 - "$QZ_ROOT/var/codex-home/config.toml" <<'PY'
import re
import sys
from pathlib import Path

for line in Path(sys.argv[1]).read_text(encoding="utf-8").splitlines():
    if line.lstrip().startswith("["):
        break
    match = re.match(r'\s*model_provider\s*=\s*"([^"]+)"', line)
    if match:
        print(match.group(1))
        break
PY
)}"
  export QZ_CODEX_MODEL_PROVIDER
}

qz_codex_profile_model() {
  local profile="${1:-}"
  python3 - "$QZ_MODEL_OVERRIDES" "$profile" <<'PY'
import json
import sys
from pathlib import Path

override_path = Path(sys.argv[1])
profile = sys.argv[2].strip()

alias_map = {
    "QwenZhai-low": "low",
    "QwenZhai-medium": "medium",
    "QwenZhai-high": "high",
    "QwenZhai-max": "max",
    "QwenZhai-caveman": "caveman",
    "Qwen3.6Turbo-low": "low",
    "Qwen3.6Turbo-medium": "medium",
    "Qwen3.6Turbo-high": "high",
    "Qwen3.6Turbo-max": "max",
    "Qwen3.6Turbo-caveman": "caveman",
}
fallback = {
    "low": "Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-IQ4_NL",
    "medium": "Qwen3.6-35B-A3B-Abliterated-Heretic-Q4_K_M",
    "high": "Qwen3.6-35B-A3B-uncensored-heretic-APEX-I-Compact",
    "max": "Qwen3.6-35B-A3B-uncensored-heretic-APEX-I-Compact",
    "caveman": "Qwen3.6-35B-A3B-Abliterated-Heretic-Q4_K_M",
}

profile_key = alias_map.get(profile, profile)
manifest = {}
if override_path.is_file():
    try:
        manifest = json.loads(override_path.read_text(encoding="utf-8"))
    except Exception:
        manifest = {}

profile_models = manifest.get("profile_models", {})
if isinstance(profile_models, dict):
    target = profile_models.get(profile_key) or profile_models.get(profile)
    if isinstance(target, str) and target:
        print(target)
        raise SystemExit(0)

print(fallback.get(profile_key, profile))
PY
}

qz_resolve_codex_profile() {
  local profile="${1:-high}"
  QZ_CODEX_MODEL=""
  QZ_CODEX_EXTRA_ARGS=()
  if [[ -n "${QZ_CODEX_MODEL_PROVIDER:-}" ]]; then
    QZ_CODEX_EXTRA_ARGS+=(-c "model_provider=\"$QZ_CODEX_MODEL_PROVIDER\"")
  fi

  case "$profile" in
    low|QwenZhai-low|Qwen3.6Turbo-low)
      QZ_CODEX_MODEL="$(qz_codex_profile_model low)"
      ;;
    medium|QwenZhai-medium|Qwen3.6Turbo-medium)
      QZ_CODEX_MODEL="$(qz_codex_profile_model medium)"
      ;;
    high|QwenZhai-high|Qwen3.6Turbo-high)
      QZ_CODEX_MODEL="$(qz_codex_profile_model high)"
      ;;
    max|QwenZhai-max|Qwen3.6Turbo-max)
      QZ_CODEX_MODEL="$(qz_codex_profile_model max)"
      ;;
    caveman|QwenZhai-caveman|Qwen3.6Turbo-caveman)
      QZ_CODEX_MODEL="$(qz_codex_profile_model caveman)"
      QZ_CODEX_EXTRA_ARGS+=(
        -c "model_instructions_file=\"$QZ_ROOT/docs/qz-caveman-codex-model-instructions-v2.md\""
        -c "model_max_output_tokens=2048"
      )
      ;;
    *) QZ_CODEX_MODEL="$profile" ;;
  esac

  export QZ_CODEX_MODEL
}
