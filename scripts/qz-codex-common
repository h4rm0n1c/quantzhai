#!/usr/bin/env bash

QZ_CODEX_COMMON_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck disable=SC1091
source "$QZ_CODEX_COMMON_DIR/qz-env"

qz_prepare_codex_home() {
  mkdir -p \
    "$QZ_VAR_DIR/codex-home/model-catalogs" \
    "$QZ_VAR_DIR/codex-home/sqlite" \
    "$QZ_VAR_DIR/logs" \
    "$QZ_VAR_DIR/run" \
    "$QZ_VAR_DIR/captures" \
    "$QZ_VAR_DIR/benchmarks"

  if [[ ! -f "$QZ_ROOT/var/codex-home/config.toml" ]]; then
    cp "$QZ_ROOT/config/codex-config.example.toml" "$QZ_ROOT/var/codex-home/config.toml"
  fi

  local catalog_dst="$QZ_ROOT/var/codex-home/model-catalogs/qwenzhai-models.json"
  python3 - "$QZ_ROOT/config/qwenzhai-models.example.json" "$QZ_MODEL_INVENTORY_CACHE" "$catalog_dst" "$QZ_ROOT/config/codex-config.example.toml" "$QZ_ROOT/var/codex-home/config.toml" <<'PY'
import json
import re
import sys
from pathlib import Path

schema_path = Path(sys.argv[1])
inventory_path = Path(sys.argv[2])
catalog_dst = Path(sys.argv[3])
config_src = Path(sys.argv[4])
config_dst = Path(sys.argv[5])


def load_json(path):
    if not path.is_file():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}

inventory = load_json(inventory_path)
inventory_models = [entry for entry in inventory.get("models", []) if isinstance(entry, dict)]
schema = load_json(schema_path)
schema_defaults = {}
if isinstance(schema, dict):
    catalog_defaults = schema.get("catalog_defaults")
    if isinstance(catalog_defaults, dict):
        schema_defaults = dict(catalog_defaults)
    else:
        schema_models = schema.get("models", [])
        if isinstance(schema_models, list):
            for item in schema_models:
                if isinstance(item, dict):
                    schema_defaults = dict(item)
                    break


def reasoning_level(entry):
    text = " ".join(
        str(value).lower()
        for value in (
            entry.get("label"),
            entry.get("name"),
            entry.get("notes"),
            entry.get("stem"),
            entry.get("backend_id"),
        )
        if value
    )
    if "apex" in text or "reasoning" in text:
        return "high"
    if "iq4" in text or "aggressive" in text or "fast" in text:
        return "low"
    return "medium"


REASONING_POLICIES = {
    "low": {
        "description": "Fast/shallow effort for simple prompts.",
        "prompt": "Use low reasoning effort. Think briefly.",
        "sampling": {
            "temperature": 0.7,
            "top_p": 0.8,
            "top_k": 20,
            "min_p": 0,
            "presence_penalty": 1.5,
            "repeat_penalty": 1.0,
        },
    },
    "medium": {
        "description": "Default coding-agent balance.",
        "prompt": "Use medium reasoning effort. Balance speed and correctness.",
        "sampling": {
            "temperature": 0.6,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0,
            "presence_penalty": 0,
            "repeat_penalty": 1.0,
        },
    },
    "high": {
        "description": "Careful reasoning for complex coding work.",
        "prompt": "Use high reasoning effort. Reason carefully before acting.",
        "sampling": {
            "temperature": 0.6,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0,
            "presence_penalty": 0,
            "repeat_penalty": 1.0,
        },
    },
    "xhigh": {
        "description": "Deep effort when complexity warrants it.",
        "prompt": "Use extra-high reasoning effort. Explore deeply when complexity warrants it.",
        "sampling": {
            "temperature": 0.6,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0,
            "presence_penalty": 0,
            "repeat_penalty": 1.0,
        },
    },
}


def supported_reasoning_levels(default_level):
    supported = []
    for effort, policy in REASONING_POLICIES.items():
        item = {
            "effort": effort,
            "description": policy["description"],
            "prompt": policy["prompt"],
            "sampling": policy["sampling"],
            "default": effort == default_level,
        }
        supported.append(item)
    return supported


def update_from_inventory(model, live):
    if not isinstance(live, dict):
        return model
    context = live.get("runtime_context_length")
    if context is None:
        context = live.get("context_length")
    if context is not None:
        model["context_window"] = context
        model["max_context_window"] = context
    notes = live.get("notes") or live.get("overrides", {}).get("notes")
    if notes:
        model["description"] = notes
    return model


def build_live_model(entry, priority):
    slug = entry.get("backend_id") or entry.get("stem") or entry.get("filename") or entry.get("key")
    if not slug:
        return None
    model = dict(schema_defaults)
    model["slug"] = slug
    label = entry.get("label") or entry.get("name") or slug
    model["display_name"] = label
    notes = entry.get("notes") or entry.get("overrides", {}).get("notes")
    model["description"] = notes or f"Local GGUF model: {label}"
    model["default_reasoning_level"] = entry.get("default_reasoning_level") or reasoning_level(entry)
    supported = entry.get("supported_reasoning_levels")
    if isinstance(supported, list) and supported:
        model["supported_reasoning_levels"] = supported
    else:
        model["supported_reasoning_levels"] = supported_reasoning_levels(model["default_reasoning_level"])
    model["priority"] = entry.get("priority") if entry.get("priority") is not None else priority
    runtime_context = entry.get("runtime_context_length")
    if runtime_context is None:
        runtime_context = entry.get("context_length")
    model["context_window"] = runtime_context or model.get("context_window")
    model["max_context_window"] = runtime_context or model.get("max_context_window")
    model["backend_id"] = slug
    model["supported_in_api"] = True
    model["visibility"] = "list"
    return model


merged_models = []
for index, entry in enumerate(inventory_models):
    backend_id = str(entry.get("backend_id") or entry.get("stem") or entry.get("key") or "")
    if not backend_id:
        continue
    live_model = build_live_model(entry, 1500 + index)
    if live_model:
        merged_models.append(update_from_inventory(live_model, entry))

catalog = {"models": merged_models}
catalog_dst.write_text(json.dumps(catalog, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")

example_config = config_src.read_text(encoding="utf-8").rstrip("\n") + "\n"
existing_config = config_dst.read_text(encoding="utf-8") if config_dst.is_file() else ""
tail = ""
if existing_config:
    lines = existing_config.splitlines(keepends=True)
    keep_block = False
    current_block = []
    tail_blocks = []
    for index, line in enumerate(lines):
        if line.startswith("["):
            if current_block:
                header = current_block[0].strip()
                if not header.startswith("[model_providers.") and not header.startswith("[profiles."):
                    tail_blocks.append("".join(current_block))
            current_block = [line]
        elif current_block:
            current_block.append(line)
    if current_block:
        header = current_block[0].strip()
        if not header.startswith("[model_providers.") and not header.startswith("[profiles."):
            tail_blocks.append("".join(current_block))
    tail = "".join(tail_blocks)

merged_config = example_config
if tail:
    merged_config += "\n" + tail.lstrip("\n")

merged_config = re.sub(
    r'(?m)^model_catalog_json\s*=\s*".*"$',
    f'model_catalog_json = "{catalog_dst}"',
    merged_config,
    count=1,
)
if not re.search(r'(?m)^model_catalog_json\s*=', merged_config):
    merged_config = f'model_catalog_json = "{catalog_dst}"\n' + merged_config

config_dst.write_text(merged_config.rstrip("\n") + "\n", encoding="utf-8")
PY

  python3 - "$QZ_ROOT/var/codex-home/config.toml" "$catalog_dst" <<'PY'
import re
import sys
from pathlib import Path

config_path = Path(sys.argv[1])
catalog_dst = Path(sys.argv[2])
text = config_path.read_text(encoding="utf-8")
catalog_line = f'model_catalog_json = "{catalog_dst}"'
if re.search(r'(?m)^model_catalog_json\s*=\s*".*"$', text):
    text = re.sub(r'(?m)^model_catalog_json\s*=\s*".*"$', catalog_line, text, count=1)
else:
    text = catalog_line + "\n" + text
config_path.write_text(text.rstrip("\n") + "\n", encoding="utf-8")
PY

  export CODEX_HOME="$QZ_ROOT/var/codex-home"
  export CODEX_SQLITE_HOME="$CODEX_HOME/sqlite"
  export CODEX_OSS_BASE_URL="http://$QZ_PROXY_HOST:$QZ_PROXY_PORT"
  export LOCAL_QWEN_API_KEY="${LOCAL_QWEN_API_KEY:-local}"

  QZ_CODEX_MODEL_PROVIDER="${QZ_CODEX_MODEL_PROVIDER:-$(python3 - "$QZ_ROOT/var/codex-home/config.toml" <<'PY'
import re
import sys
from pathlib import Path

for line in Path(sys.argv[1]).read_text(encoding="utf-8").splitlines():
    if line.lstrip().startswith("["):
        break
    match = re.match(r'\s*model_provider\s*=\s*"([^"]+)"', line)
    if match:
        print(match.group(1))
        break
PY
)}"
  export QZ_CODEX_MODEL_PROVIDER
}

qz_codex_profile_model() {
  local profile="${1:-}"
  python3 - "$QZ_MODEL_INVENTORY_CACHE" "$QZ_ROOT/config/qz-model-overrides.example.json" "$QZ_MODEL_OVERRIDES" "$profile" <<'PY'
import json
import sys
from pathlib import Path

inventory_path = Path(sys.argv[1])
base_path = Path(sys.argv[2])
override_path = Path(sys.argv[3])
profile = sys.argv[4].strip()

def load_json(path):
    if not path.is_file():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def deep_merge(base, overlay):
    if not isinstance(base, dict) or not isinstance(overlay, dict):
        return overlay if isinstance(overlay, dict) else base
    result = dict(base)
    for key, value in overlay.items():
        existing = result.get(key)
        if isinstance(existing, dict) and isinstance(value, dict):
            result[key] = deep_merge(existing, value)
        else:
            result[key] = value
    return result


def add_lookup(index, value, entry):
    if isinstance(value, str) and value.strip():
        index.setdefault(value.strip().lower(), entry)


inventory = load_json(inventory_path)
entries = [entry for entry in inventory.get("models", []) if isinstance(entry, dict)]
index = {}
for entry in entries:
    for key in (
        entry.get("backend_id"),
        entry.get("stem"),
        entry.get("filename"),
        entry.get("key"),
        entry.get("name"),
        entry.get("label"),
    ):
        add_lookup(index, key, entry)
    for alias in entry.get("aliases", []):
        add_lookup(index, alias, entry)

manifest = {}
for path in (base_path, override_path):
    manifest = deep_merge(manifest, load_json(path))

default_key = manifest.get("default_key")
if isinstance(default_key, str) and default_key.strip():
    resolved = index.get(default_key.strip().lower())
    if resolved:
        backend_id = resolved.get("backend_id") or resolved.get("stem") or resolved.get("filename") or resolved.get("key")
        if isinstance(backend_id, str) and backend_id.strip():
            print(backend_id.strip())
            raise SystemExit(0)

direct = index.get(profile.lower())
if direct:
    backend_id = direct.get("backend_id") or direct.get("stem") or direct.get("filename") or direct.get("key")
    if isinstance(backend_id, str) and backend_id.strip():
        print(backend_id.strip())
        raise SystemExit(0)

print(profile)
PY
}

qz_codex_model_context_window() {
  local model="${1:-}"
  [[ -z "$model" ]] && return 0
  python3 - "$QZ_MODEL_INVENTORY_CACHE" "$QZ_ROOT/config/qz-model-overrides.example.json" "$QZ_MODEL_OVERRIDES" "$model" <<'PY'
import json
import sys
from pathlib import Path

inventory_path = Path(sys.argv[1])
base_path = Path(sys.argv[2])
override_path = Path(sys.argv[3])
query = sys.argv[4].strip().lower()

def load_json(path):
    if not path.is_file():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}

def deep_merge(base, overlay):
    if not isinstance(base, dict) or not isinstance(overlay, dict):
        return overlay if isinstance(overlay, dict) else base
    result = dict(base)
    for key, value in overlay.items():
        existing = result.get(key)
        if isinstance(existing, dict) and isinstance(value, dict):
            result[key] = deep_merge(existing, value)
        else:
            result[key] = value
    return result

inventory = load_json(inventory_path)
entries = [entry for entry in inventory.get("models", []) if isinstance(entry, dict)]
manifest = {}
for path in (base_path, override_path):
    manifest = deep_merge(manifest, load_json(path))
models = manifest.get("models") if isinstance(manifest.get("models"), dict) else {}

for entry in entries:
    keys = [
        entry.get("backend_id"),
        entry.get("stem"),
        entry.get("filename"),
        entry.get("key"),
        entry.get("name"),
        entry.get("label"),
    ]
    keys.extend(entry.get("aliases", []))
    if not any(isinstance(key, str) and key.strip().lower() == query for key in keys):
        continue
    runtime_context = None
    if isinstance(models, dict):
        for key in keys:
            if isinstance(key, str) and key in models and isinstance(models[key], dict):
                overrides = models[key]
                runtime_context = overrides.get("runtime_context_length") or overrides.get("context_length")
                if runtime_context is not None:
                    break
    if runtime_context is None:
        runtime_context = entry.get("runtime_context_length") or entry.get("context_length")
    if runtime_context is None:
        raise SystemExit(0)
    try:
        print(int(runtime_context))
    except Exception:
        pass
    raise SystemExit(0)
PY
}

qz_resolve_codex_profile() {
  local profile="${1:-high}"
  QZ_CODEX_MODEL=""
  QZ_CODEX_EXTRA_ARGS=()
  if [[ -n "${QZ_CODEX_MODEL_PROVIDER:-}" ]]; then
    QZ_CODEX_EXTRA_ARGS+=(-c "model_provider=\"$QZ_CODEX_MODEL_PROVIDER\"")
  fi

  case "$profile" in
    low)
      QZ_CODEX_MODEL="$(qz_codex_profile_model low)"
      ;;
    medium)
      QZ_CODEX_MODEL="$(qz_codex_profile_model medium)"
      ;;
    high)
      QZ_CODEX_MODEL="$(qz_codex_profile_model high)"
      ;;
    max)
      QZ_CODEX_MODEL="$(qz_codex_profile_model max)"
      ;;
    caveman)
      QZ_CODEX_MODEL="$(qz_codex_profile_model caveman)"
      QZ_CODEX_EXTRA_ARGS+=(
        -c "model_instructions_file=\"$QZ_ROOT/docs/qz-caveman-codex-model-instructions-v2.md\""
        -c "model_max_output_tokens=2048"
      )
      ;;
    *) QZ_CODEX_MODEL="$profile" ;;
  esac

  local model_context_window
  model_context_window="$(qz_codex_model_context_window "$QZ_CODEX_MODEL")"
  if [[ -n "$model_context_window" ]]; then
    QZ_CODEX_EXTRA_ARGS+=(-c "model_context_window=$model_context_window")
  fi

  export QZ_CODEX_MODEL
}

qz_proxy_loaded_model() {
  python3 - "$QZ_PROXY_HOST" "$QZ_PROXY_PORT" <<'PY'
import json
import sys
import urllib.request

host, port = sys.argv[1:]
url = f"http://{host}:{port}/qz/status"
try:
    with urllib.request.urlopen(url, timeout=2.0) as response:
        payload = json.loads(response.read().decode("utf-8"))
except Exception:
    sys.exit(0)

backend = payload.get("backend") if isinstance(payload, dict) else {}
if not isinstance(backend, dict):
    sys.exit(0)

for key in ("selected_key", "selected_backend_id", "loaded_model"):
    value = backend.get(key)
    if isinstance(value, str) and value.strip():
        print(value.strip())
        break
PY
}

qz_sync_codex_model() {
  local model="${1:-}"
  [[ -z "$model" ]] && return 0
  local timeout="${QZ_MODEL_LOAD_TIMEOUT:-120}"

  python3 - "$QZ_PROXY_HOST" "$QZ_PROXY_PORT" "$model" "$timeout" <<'PY'
import json
import sys
import time
import urllib.error
import urllib.request

host, port, model, timeout_s = sys.argv[1:]
timeout = float(timeout_s)
health_url = f"http://{host}:{port}/health"
url = f"http://{host}:{port}/qz/models/select"
body = json.dumps({"model": model}).encode("utf-8")

deadline = time.time() + timeout
while time.time() < deadline:
    try:
        with urllib.request.urlopen(health_url, timeout=5) as response:
            if response.status == 200:
                break
    except Exception:
        time.sleep(1)
else:
    print(f"qz-codex: model sync skipped: proxy not ready at {health_url}", file=sys.stderr)
    sys.exit(0)

try:
    request = urllib.request.Request(
        url,
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=timeout) as response:
        raw = response.read().decode("utf-8", "replace")
    payload = json.loads(raw) if raw else {}
    backend = payload.get("backend") if isinstance(payload, dict) else {}
    loaded_model = ""
    if isinstance(backend, dict):
        loaded_model = backend.get("selected_key") or backend.get("selected_backend_id") or backend.get("loaded_model") or ""
    if loaded_model:
        print(f"qz-codex: synced backend model {loaded_model}", file=sys.stderr)
except urllib.error.HTTPError as exc:
    detail = exc.read().decode("utf-8", "replace").strip()
    if detail:
        print(f"qz-codex: model sync skipped ({exc.code}): {detail}", file=sys.stderr)
    else:
        print(f"qz-codex: model sync skipped ({exc.code})", file=sys.stderr)
except Exception as exc:
    print(f"qz-codex: model sync skipped: {exc}", file=sys.stderr)
PY
}
