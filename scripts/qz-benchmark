#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/qz-codex-common"

usage() {
  cat <<'EOF'
Usage: scripts/qz-benchmark [options] [profile ...]

Run fixed prompts through Codex exec and write benchmark artifacts under var/.

Options:
  --prompts FILE       Prompt fixture JSON (default: config/qz-benchmark-prompts.json)
  --output-dir DIR     Benchmark output root (default: var/benchmarks)
  --run-id ID          Run id (default: UTC timestamp)
  --only ID            Run only one prompt id; repeatable
  --sandbox MODE       Codex sandbox mode (default: read-only)
  --approval POLICY    Codex approval policy (default: never)
  --timeout SECONDS    Per-case timeout (default: 900)
  --no-ephemeral       Persist Codex exec sessions
  --no-manage-proxy    Do not start a temporary proxy if proxy health is down
  --search             Enable Codex web search for benchmark runs
  --dry-run            Print planned runs without executing Codex
  -h, --help           Show this help

Default profiles: high caveman
EOF
}

prompts_file="$QZ_ROOT/config/qz-benchmark-prompts.json"
output_dir="$QZ_VAR_DIR/benchmarks"
run_id="$(date -u +%Y%m%dT%H%M%SZ)"
sandbox_mode="read-only"
approval_policy="never"
timeout_seconds=900
ephemeral=1
manage_proxy=1
enable_search=0
dry_run=0
profiles=()
only_ids=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --prompts)
      prompts_file="$2"
      shift 2
      ;;
    --output-dir)
      output_dir="$2"
      shift 2
      ;;
    --run-id)
      run_id="$2"
      shift 2
      ;;
    --only)
      only_ids+=("$2")
      shift 2
      ;;
    --sandbox)
      sandbox_mode="$2"
      shift 2
      ;;
    --approval)
      approval_policy="$2"
      shift 2
      ;;
    --timeout)
      timeout_seconds="$2"
      shift 2
      ;;
    --no-ephemeral)
      ephemeral=0
      shift
      ;;
    --no-manage-proxy)
      manage_proxy=0
      shift
      ;;
    --search)
      enable_search=1
      shift
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        profiles+=("$1")
        shift
      done
      ;;
    -*)
      printf 'unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
    *)
      profiles+=("$1")
      shift
      ;;
  esac
done

if [[ ${#profiles[@]} -eq 0 ]]; then
  profiles=(high caveman)
fi

if [[ ! -f "$prompts_file" ]]; then
  printf 'prompt fixture not found: %s\n' "$prompts_file" >&2
  exit 1
fi

qz_prepare_codex_home

proxy_started=0
proxy_pid=""

http_ok() {
  curl -fsS "$1" >/dev/null 2>&1
}

cleanup_proxy() {
  if [[ "$proxy_started" == "1" && -n "$proxy_pid" ]] && kill -0 "$proxy_pid" 2>/dev/null; then
    kill "$proxy_pid" 2>/dev/null || true
    wait "$proxy_pid" 2>/dev/null || true
  fi
}

trap cleanup_proxy EXIT

ensure_proxy() {
  if [[ "$manage_proxy" != "1" || "$dry_run" == "1" ]]; then
    return
  fi

  local proxy_url="http://$QZ_PROXY_HOST:$QZ_PROXY_PORT/health"
  local backend_url="http://$QZ_SERVER_HOST:$QZ_SERVER_PORT/health"
  local proxy_log="$QZ_VAR_DIR/logs/qz-benchmark-proxy.log"

  if http_ok "$proxy_url"; then
    return
  fi

  if ! http_ok "$backend_url"; then
    printf 'backend is not healthy: %s\n' "$backend_url" >&2
    printf 'run scripts/qz-up first, then rerun scripts/qz-benchmark\n' >&2
    exit 1
  fi

  printf 'proxy not healthy; starting temporary proxy for benchmark\n' >&2
  python3 "$QZ_ROOT/proxy/quantzhai_proxy.py" \
    --listen "$QZ_PROXY_HOST" \
    --port "$QZ_PROXY_PORT" \
    --upstream "http://$QZ_SERVER_HOST:$QZ_SERVER_PORT" \
    --reasoning-stream-format summary \
    > "$proxy_log" 2>&1 &
  proxy_pid="$!"
  proxy_started=1

  for _ in $(seq 1 50); do
    if http_ok "$proxy_url"; then
      return
    fi
    if ! kill -0 "$proxy_pid" 2>/dev/null; then
      printf 'temporary proxy exited; see %s\n' "$proxy_log" >&2
      sed -n '1,120p' "$proxy_log" >&2 || true
      exit 1
    fi
    sleep 0.1
  done

  printf 'temporary proxy did not become healthy: %s\n' "$proxy_url" >&2
  sed -n '1,120p' "$proxy_log" >&2 || true
  exit 1
}

ensure_proxy

run_dir="$output_dir/$run_id"
mkdir -p "$run_dir"
prompts_jsonl="$run_dir/prompts.jsonl"

python3 - "$prompts_file" "${only_ids[@]}" > "$prompts_jsonl" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
only = set(sys.argv[2:])
data = json.loads(path.read_text(encoding="utf-8"))
prompts = data.get("prompts", [])
if only:
    prompts = [prompt for prompt in prompts if prompt.get("id") in only]
missing = only - {prompt.get("id") for prompt in prompts}
if missing:
    raise SystemExit(f"missing prompt ids: {', '.join(sorted(missing))}")
if not prompts:
    raise SystemExit("no prompts selected")
for prompt in prompts:
    if not prompt.get("id") or not prompt.get("prompt"):
        raise SystemExit("each prompt needs id and prompt")
    print(json.dumps(prompt, ensure_ascii=False, sort_keys=True))
PY

python3 - "$run_dir" "$run_id" "$prompts_file" "$sandbox_mode" "$approval_policy" "$timeout_seconds" "$ephemeral" "$enable_search" "$manage_proxy" "${profiles[@]}" <<'PY'
import json
import sys
from pathlib import Path

run_dir = Path(sys.argv[1])
metadata = {
    "run_id": sys.argv[2],
    "prompts_file": sys.argv[3],
    "sandbox_mode": sys.argv[4],
    "approval_policy": sys.argv[5],
    "timeout_seconds": int(sys.argv[6]),
    "ephemeral": sys.argv[7] == "1",
    "search": sys.argv[8] == "1",
    "manage_proxy": sys.argv[9] == "1",
    "profiles": sys.argv[10:],
}
(run_dir / "metadata.json").write_text(json.dumps(metadata, indent=2) + "\n", encoding="utf-8")
PY

safe_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '-'
}

now_seconds() {
  python3 - <<'PY'
import time
print(f"{time.time():.6f}")
PY
}

clear_latest_captures() {
  rm -f \
    "$QZ_VAR_DIR/captures/latest-request.json" \
    "$QZ_VAR_DIR/captures/latest-normalized-request.json" \
    "$QZ_VAR_DIR/captures/latest-forwarded.json" \
    "$QZ_VAR_DIR/captures/latest-upstream-response.raw" \
    "$QZ_VAR_DIR/captures/latest-upstream-status.txt" \
    "$QZ_VAR_DIR/captures/latest-synthetic-sse.raw" \
    "$QZ_VAR_DIR/captures/latest-web-runtime-final.json"
}

copy_latest_captures() {
  local capture_dir="$1"
  mkdir -p "$capture_dir"
  local name
  for name in \
    latest-request.json \
    latest-normalized-request.json \
    latest-forwarded.json \
    latest-upstream-response.raw \
    latest-upstream-status.txt \
    latest-synthetic-sse.raw \
    latest-web-runtime-final.json \
    latest-json-api.log; do
    if [[ -f "$QZ_VAR_DIR/captures/$name" ]]; then
      cp "$QZ_VAR_DIR/captures/$name" "$capture_dir/$name"
    fi
  done
}

case_index=0
while IFS= read -r prompt_json; do
  prompt_id="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1])["id"])' "$prompt_json")"
  prompt_text="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1])["prompt"])' "$prompt_json")"
  prompt_slug="$(safe_name "$prompt_id")"

  for profile in "${profiles[@]}"; do
    case_index=$((case_index + 1))
    qz_resolve_codex_profile "$profile"
    profile_slug="$(safe_name "$profile")"
    case_dir="$run_dir/$(printf '%03d' "$case_index")-$profile_slug-$prompt_slug"
    mkdir -p "$case_dir"

    printf '%s\n' "$prompt_text" > "$case_dir/prompt.txt"
    printf '%s\n' "$profile" > "$case_dir/profile.txt"
    printf '%s\n' "$QZ_CODEX_MODEL" > "$case_dir/model.txt"

    cmd=(codex -a "$approval_policy")
    if [[ "$enable_search" == "1" ]]; then
      cmd+=(--search)
    fi
    cmd+=(
      exec
      --json
      --color never
      -C "$QZ_ROOT"
      -m "$QZ_CODEX_MODEL"
      -s "$sandbox_mode"
      -o "$case_dir/final.txt"
    )
    if [[ "$ephemeral" == "1" ]]; then
      cmd+=(--ephemeral)
    fi
    cmd+=("${QZ_CODEX_EXTRA_ARGS[@]}" -- "$prompt_text")

    printf '%q ' "${cmd[@]}" > "$case_dir/command.sh"
    printf '\n' >> "$case_dir/command.sh"

    if [[ "$dry_run" == "1" ]]; then
      printf '[dry-run] %s %s -> %s\n' "$profile" "$prompt_id" "$case_dir"
      continue
    fi

    printf 'running profile=%s model=%s prompt=%s\n' "$profile" "$QZ_CODEX_MODEL" "$prompt_id"
    clear_latest_captures
    start_ts="$(now_seconds)"
    set +e
    if command -v timeout >/dev/null 2>&1; then
      timeout "$timeout_seconds" "${cmd[@]}" > "$case_dir/events.jsonl" 2> "$case_dir/stderr.txt"
      exit_code=$?
    else
      "${cmd[@]}" > "$case_dir/events.jsonl" 2> "$case_dir/stderr.txt"
      exit_code=$?
    fi
    set -e
    end_ts="$(now_seconds)"
    timed_out=0
    if [[ "$exit_code" == "124" ]]; then
      timed_out=1
    fi
    copy_latest_captures "$case_dir/captures"

    python3 - "$case_dir" "$profile" "$QZ_CODEX_MODEL" "$prompt_id" "$exit_code" "$timed_out" "$start_ts" "$end_ts" <<'PY'
import hashlib
import json
import math
import sys
from pathlib import Path

case_dir = Path(sys.argv[1])
profile = sys.argv[2]
model = sys.argv[3]
prompt_id = sys.argv[4]
exit_code = int(sys.argv[5])
timed_out = sys.argv[6] == "1"
start_ts = float(sys.argv[7])
end_ts = float(sys.argv[8])

def approx_tokens(text):
    if not text:
        return 0
    return max(1, math.ceil(len(text) / 4))

def token_count(value, fallback=0):
    try:
        return int(value)
    except Exception:
        return fallback

def load_json(path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None

def load_jsonish(path):
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return None
    text = text.strip()
    if not text:
        return None
    try:
        return json.loads(text)
    except Exception:
        return None

def walk(value):
    if isinstance(value, dict):
        yield value
        for child in value.values():
            yield from walk(child)
    elif isinstance(value, list):
        for child in value:
            yield from walk(child)

def collect_usages(value):
    usages = []
    for item in walk(value):
        keys = set(item)
        if {"input_tokens", "output_tokens"}.issubset(keys) or {"prompt_tokens", "completion_tokens"}.issubset(keys):
            input_tokens = token_count(item.get("input_tokens"), token_count(item.get("prompt_tokens")))
            output_tokens = token_count(item.get("output_tokens"), token_count(item.get("completion_tokens")))
            total_tokens = token_count(item.get("total_tokens"), input_tokens + output_tokens)
            usages.append({
                "input_tokens": input_tokens,
                "output_tokens": output_tokens,
                "total_tokens": max(total_tokens, input_tokens + output_tokens),
            })
    return usages

def best_usage(usages):
    if not usages:
        return {}
    return max(usages, key=lambda usage: usage.get("total_tokens", 0))

events = []
events_path = case_dir / "events.jsonl"
if events_path.exists():
    for line in events_path.read_text(encoding="utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            events.append(json.loads(line))
        except Exception:
            pass

final_text = ""
final_path = case_dir / "final.txt"
if final_path.exists():
    final_text = final_path.read_text(encoding="utf-8", errors="replace")

captures = case_dir / "captures"
request = load_json(captures / "latest-request.json") if captures.exists() else None
normalized_request = load_json(captures / "latest-normalized-request.json") if captures.exists() else None
runtime_final = load_json(captures / "latest-web-runtime-final.json") if captures.exists() else None
upstream_raw = load_jsonish(captures / "latest-upstream-response.raw") if captures.exists() else None

request_body = normalized_request or request or {}
instructions = request_body.get("instructions") if isinstance(request_body, dict) else None
if not isinstance(instructions, str):
    instructions = ""

sse_done = False
sse_path = captures / "latest-synthetic-sse.raw"
if sse_path.exists():
    try:
        sse_done = b"data: [DONE]" in sse_path.read_bytes()
    except Exception:
        sse_done = False

usage_sources = {
    "codex_events": best_usage([usage for event in events for usage in collect_usages(event)]),
    "runtime_final": best_usage(collect_usages(runtime_final)),
    "upstream_raw": best_usage(collect_usages(upstream_raw)),
}
preferred_usage = (
    usage_sources["codex_events"]
    or usage_sources["runtime_final"]
    or usage_sources["upstream_raw"]
    or {}
)

finish_reasons = []
for source in [events, runtime_final, upstream_raw]:
    for item in walk(source):
        reason = item.get("finish_reason") or item.get("finish_details")
        if reason:
            finish_reasons.append(reason)

result = {
    "profile": profile,
    "model": model,
    "prompt_id": prompt_id,
    "exit_code": exit_code,
    "timed_out": timed_out,
    "wall_seconds": round(max(0.0, end_ts - start_ts), 3),
    "event_count": len(events),
    "final_chars": len(final_text),
    "final_est_tokens": approx_tokens(final_text),
    "usage": preferred_usage,
    "usage_sources": usage_sources,
    "request": {
        "model": request_body.get("model") if isinstance(request_body, dict) else None,
        "instructions_chars": len(instructions),
        "instructions_est_tokens": approx_tokens(instructions),
        "instructions_sha256": hashlib.sha256(instructions.encode("utf-8")).hexdigest() if instructions else "",
        "body_chars": len(json.dumps(request_body, ensure_ascii=False)) if isinstance(request_body, dict) else 0,
    },
    "sse_done": sse_done,
    "finish_reason": finish_reasons[-1] if finish_reasons else None,
}
(case_dir / "result.json").write_text(json.dumps(result, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
PY
  done
done < "$prompts_jsonl"

if [[ "$dry_run" == "1" ]]; then
  printf 'dry-run complete: %s\n' "$run_dir"
  exit 0
fi

python3 - "$run_dir" "$output_dir" <<'PY'
import json
import math
import shutil
import sys
from collections import defaultdict
from datetime import datetime, timezone
from pathlib import Path

run_dir = Path(sys.argv[1])
output_dir = Path(sys.argv[2])

metadata = json.loads((run_dir / "metadata.json").read_text(encoding="utf-8"))
results = []
for path in sorted(run_dir.glob("*/result.json")):
    result = json.loads(path.read_text(encoding="utf-8"))
    result["case_dir"] = path.parent.name
    results.append(result)

profiles = metadata.get("profiles") or []
baseline_profile = "high" if "high" in profiles else (profiles[0] if profiles else "")

def metric_tokens(result, kind):
    usage = result.get("usage") or {}
    value = usage.get(f"{kind}_tokens")
    if isinstance(value, int) and value > 0:
        return value
    if kind == "output":
        return int(result.get("final_est_tokens") or 0)
    return 0

def request_metric(result, key):
    request = result.get("request") or {}
    value = request.get(key)
    return value if isinstance(value, int) and value > 0 else 0

def ratio(value, baseline):
    return round(value / baseline, 4) if baseline else None

def savings(value, baseline):
    return round(1 - (value / baseline), 4) if baseline else None

by_prompt_profile = {(result["prompt_id"], result["profile"]): result for result in results}
comparisons = []
aggregate_values = defaultdict(lambda: {
    "input_ratios": [],
    "instruction_ratios": [],
    "final_ratios": [],
    "api_output_ratios": [],
    "total_ratios": [],
    "wall_ratios": [],
})

for result in results:
    baseline = by_prompt_profile.get((result["prompt_id"], baseline_profile))
    if not baseline or result["profile"] == baseline_profile:
        continue

    input_tokens = metric_tokens(result, "input")
    baseline_input = metric_tokens(baseline, "input")
    instruction_tokens = request_metric(result, "instructions_est_tokens")
    baseline_instruction = request_metric(baseline, "instructions_est_tokens")
    final_tokens = int(result.get("final_est_tokens") or 0)
    baseline_final = int(baseline.get("final_est_tokens") or 0)
    output_tokens = metric_tokens(result, "output")
    baseline_output = metric_tokens(baseline, "output")
    total_tokens = metric_tokens(result, "total")
    baseline_total = metric_tokens(baseline, "total")
    wall_seconds = float(result.get("wall_seconds") or 0)
    baseline_wall = float(baseline.get("wall_seconds") or 0)

    comparison = {
        "profile": result["profile"],
        "prompt_id": result["prompt_id"],
        "input_tokens": input_tokens,
        "baseline_input_tokens": baseline_input,
        "input_ratio": ratio(input_tokens, baseline_input),
        "input_savings": savings(input_tokens, baseline_input),
        "instructions_est_tokens": instruction_tokens,
        "baseline_instructions_est_tokens": baseline_instruction,
        "instructions_ratio": ratio(instruction_tokens, baseline_instruction),
        "instructions_savings": savings(instruction_tokens, baseline_instruction),
        "final_est_tokens": final_tokens,
        "baseline_final_est_tokens": baseline_final,
        "final_ratio": ratio(final_tokens, baseline_final),
        "final_savings": savings(final_tokens, baseline_final),
        "api_output_tokens": output_tokens,
        "baseline_api_output_tokens": baseline_output,
        "api_output_ratio": ratio(output_tokens, baseline_output),
        "api_output_savings": savings(output_tokens, baseline_output),
        "total_tokens": total_tokens,
        "baseline_total_tokens": baseline_total,
        "total_ratio": ratio(total_tokens, baseline_total),
        "wall_ratio": ratio(wall_seconds, baseline_wall),
    }
    comparisons.append(comparison)
    store = aggregate_values[result["profile"]]
    if comparison["input_ratio"] is not None:
        store["input_ratios"].append(comparison["input_ratio"])
    if comparison["instructions_ratio"] is not None:
        store["instruction_ratios"].append(comparison["instructions_ratio"])
    if comparison["final_ratio"] is not None:
        store["final_ratios"].append(comparison["final_ratio"])
    if comparison["api_output_ratio"] is not None:
        store["api_output_ratios"].append(comparison["api_output_ratio"])
    if comparison["total_ratio"] is not None:
        store["total_ratios"].append(comparison["total_ratio"])
    if comparison["wall_ratio"] is not None:
        store["wall_ratios"].append(comparison["wall_ratio"])

def average(values):
    return round(sum(values) / len(values), 4) if values else None

aggregate = {}
for profile, values in aggregate_values.items():
    input_ratio = average(values["input_ratios"])
    instruction_ratio = average(values["instruction_ratios"])
    final_ratio = average(values["final_ratios"])
    api_output_ratio = average(values["api_output_ratios"])
    total_ratio = average(values["total_ratios"])
    wall_ratio = average(values["wall_ratios"])
    aggregate[profile] = {
        "cases": len(values["input_ratios"]),
        "avg_input_ratio": input_ratio,
        "avg_input_savings": round(1 - input_ratio, 4) if input_ratio is not None else None,
        "avg_instructions_ratio": instruction_ratio,
        "avg_instructions_savings": round(1 - instruction_ratio, 4) if instruction_ratio is not None else None,
        "avg_final_ratio": final_ratio,
        "avg_final_savings": round(1 - final_ratio, 4) if final_ratio is not None else None,
        "avg_api_output_ratio": api_output_ratio,
        "avg_api_output_savings": round(1 - api_output_ratio, 4) if api_output_ratio is not None else None,
        "avg_total_ratio": total_ratio,
        "avg_wall_ratio": wall_ratio,
    }

summary = {
    "run_id": metadata.get("run_id"),
    "created_at": datetime.now(timezone.utc).isoformat(),
    "baseline_profile": baseline_profile,
    "profiles": profiles,
    "prompt_count": len({result["prompt_id"] for result in results}),
    "case_count": len(results),
    "aggregate": aggregate,
    "comparisons": comparisons,
    "results": results,
}

summary_path = run_dir / "summary.json"
summary_path.write_text(json.dumps(summary, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")

lines = [
    f"# QuantZhai Benchmark {summary['run_id']}",
    "",
    f"Baseline profile: `{baseline_profile}`",
    "",
    "## Aggregate",
    "",
    "| Profile | Cases | Avg input ratio | Avg input savings | Avg instr ratio | Avg final ratio | Avg total ratio | Avg wall ratio |",
    "| --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: |",
]
for profile, row in sorted(aggregate.items()):
    lines.append(
        f"| {profile} | {row['cases']} | {row['avg_input_ratio']} | "
        f"{row['avg_input_savings']} | {row['avg_instructions_ratio']} | "
        f"{row['avg_final_ratio']} | {row['avg_total_ratio']} | {row['avg_wall_ratio']} |"
    )

lines.extend([
    "",
    "## Cases",
    "",
    "| Profile | Prompt | Exit | Wall s | Instr est tok | Input tok | API output tok | Final est tok | Total tok |",
    "| --- | --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: |",
])
for result in results:
    usage = result.get("usage") or {}
    request = result.get("request") or {}
    lines.append(
        f"| {result['profile']} | {result['prompt_id']} | {result['exit_code']} | "
        f"{result['wall_seconds']} | {request.get('instructions_est_tokens', 0)} | "
        f"{usage.get('input_tokens', 0)} | {usage.get('output_tokens', 0)} | "
        f"{result.get('final_est_tokens', 0)} | {usage.get('total_tokens', 0)} |"
    )

(run_dir / "summary.md").write_text("\n".join(lines) + "\n", encoding="utf-8")

output_dir.mkdir(parents=True, exist_ok=True)
shutil.copy2(summary_path, output_dir / "latest-summary.json")
(output_dir / "latest-run.txt").write_text(str(run_dir) + "\n", encoding="utf-8")

print(f"summary: {run_dir / 'summary.md'}")
if aggregate:
    for profile, row in sorted(aggregate.items()):
        print(
            f"{profile}: avg_input_ratio={row['avg_input_ratio']} "
            f"avg_input_savings={row['avg_input_savings']} "
            f"avg_instructions_ratio={row['avg_instructions_ratio']} "
            f"avg_final_ratio={row['avg_final_ratio']}"
        )
PY
