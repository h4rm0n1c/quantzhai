#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -f "$SCRIPT_DIR/qz-env" ]]; then
  source "$SCRIPT_DIR/qz-env"
fi

set +e
set +u
set +o pipefail 2>/dev/null

python3 - "$@" <<'PY'
import argparse
import curses
import json
import os
import re
import shlex
import signal
import subprocess
import sys
import time
import urllib.request
from dataclasses import dataclass
from typing import List, Optional, Tuple

@dataclass
class GpuRow:
    index: str
    name: str
    util: float
    mem_used: float
    mem_total: float
    power: float
    temp: float
    gen: str
    width: str


@dataclass
class Rates:
    requests: int = 0
    checkpoints: int = 0
    restores: int = 0
    oom: int = 0
    prompt_latest: float = 0.0
    prompt_max: float = 0.0
    prompt_tokens: int = 0
    prompt_ms: float = 0.0
    gen_latest: float = 0.0
    gen_max: float = 0.0
    gen_tokens: int = 0
    gen_ms: float = 0.0
    total_latest: float = 0.0
    total_max: float = 0.0
    total_tokens: int = 0
    total_ms: float = 0.0
    recent: List[Tuple[str, str]] = None


@dataclass
class BenchmarkSummary:
    run_id: str = ""
    baseline: str = ""
    profiles: int = 0
    cases: int = 0
    prompt_count: int = 0
    best_profile: str = ""
    best_input_ratio: float = 0.0
    best_input_savings: float = 0.0
    best_instructions_ratio: float = 0.0
    best_final_ratio: float = 0.0
    best_total_ratio: float = 0.0
    best_wall_ratio: float = 0.0


@dataclass
class ModelStatus:
    ready: bool = False
    selected: str = ""
    selected_state: str = ""
    loaded: str = ""
    loaded_count: int = 0
    load_state: str = ""
    error: str = ""


def run_cmd(args, timeout=2.0) -> str:
    try:
        return subprocess.check_output(
            args,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout,
        )
    except subprocess.CalledProcessError as exc:
        return (exc.output or str(exc)).strip()
    except Exception as exc:
        return str(exc)


def docker_cmd() -> List[str]:
    raw = os.environ.get("QZ_DOCKER_CMD", "docker")
    return shlex.split(raw)


def docker(args: List[str], timeout=3.0) -> str:
    return run_cmd(docker_cmd() + args, timeout=timeout)


def curl_health(host: str, port: str) -> bool:
    try:
        out = subprocess.check_output(
            ["curl", "-fsS", f"http://{host}:{port}/health"],
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=1.0,
        )
    except Exception:
        return False
    return "status" in out or out.strip() == "OK" or out.strip() == "ok"


def proxy_base_url() -> str:
    host = os.environ.get("QZ_PROXY_HOST", "127.0.0.1")
    port = os.environ.get("QZ_PROXY_PORT", "18180")
    return f"http://{host}:{port}"


def fetch_json(url: str, timeout: float = 0.5) -> Optional[dict]:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except Exception:
        return None


def telemetry_recent(limit: int = 30) -> Optional[dict]:
    return fetch_json(f"{proxy_base_url()}/qz/telemetry/recent?limit={limit}")


def proxy_status() -> Optional[dict]:
    return fetch_json(f"{proxy_base_url()}/qz/status")


def model_status_from_proxy(status: Optional[dict]) -> ModelStatus:
    if not isinstance(status, dict):
        return ModelStatus()
    backend = status.get("backend") if isinstance(status.get("backend"), dict) else {}
    load = status.get("load") if isinstance(status.get("load"), dict) else {}
    loaded_model = backend.get("loaded_model") if isinstance(backend.get("loaded_model"), str) else ""
    loaded_models = backend.get("loaded_models") if isinstance(backend.get("loaded_models"), list) else []
    loaded_ids = [
        str(model.get("id"))
        for model in loaded_models
        if isinstance(model, dict) and model.get("id")
    ]
    if not loaded_ids:
        backend_models = backend.get("models") if isinstance(backend.get("models"), dict) else {}
        loaded_ids = [
            str(model_id)
            for model_id, entry in backend_models.items()
            if isinstance(entry, dict) and entry.get("state") == "loaded"
        ]
    if not loaded_model and loaded_ids:
        loaded_model = loaded_ids[0]
    selected = backend.get("selected_backend_id") or backend.get("selected_key") or ""
    return ModelStatus(
        ready=bool(status.get("ready")),
        selected=str(selected),
        selected_state=str(backend.get("selected_state") or ""),
        loaded=str(loaded_model or ""),
        loaded_count=int(backend.get("loaded_count") or len(loaded_ids) or 0),
        load_state=str(load.get("state") or ""),
        error=str(load.get("error") or ""),
    )


def parse_num(text: str) -> float:
    try:
        return float(str(text).strip())
    except Exception:
        return 0.0


def human_si(value: float, suffix: str = "", precision: int = 1) -> str:
    try:
        value = float(value)
    except Exception:
        value = 0.0
    sign = "-" if value < 0 else ""
    value = abs(value)
    if value == 0:
        return f"0{suffix}"
    units = ["", "k", "M", "G", "T", "P", "E"]
    idx = 0
    while value >= 1000.0 and idx < len(units) - 1:
        value /= 1000.0
        idx += 1
    if idx == 0:
        text = f"{value:.0f}" if value >= 100 else f"{value:.{precision}f}"
    else:
        text = f"{value:.{precision}f}"
    return f"{sign}{text}{units[idx]}{suffix}"


def human_bytes_from_mib(value: float, compact: bool = False) -> str:
    try:
        value = float(value)
    except Exception:
        value = 0.0
    units = ["MiB", "GiB", "TiB", "PiB"]
    idx = 0
    while value >= 1024.0 and idx < len(units) - 1:
        value /= 1024.0
        idx += 1
    text = f"{value:.0f}" if idx == 0 else f"{value:.1f}"
    sep = "" if compact else " "
    return f"{text}{sep}{units[idx]}"


def human_duration_ms(ms: float) -> str:
    try:
        ms = float(ms)
    except Exception:
        ms = 0.0
    if ms < 1000.0:
        return f"{ms:.0f}ms"
    seconds = ms / 1000.0
    if seconds < 60.0:
        return f"{seconds:.1f}s"
    minutes = seconds / 60.0
    if minutes < 60.0:
        return f"{minutes:.1f}m"
    hours = minutes / 60.0
    return f"{hours:.1f}h"


def vram_summary(gpus: List[GpuRow]) -> Tuple[float, float, float]:
    used = sum(max(0.0, gpu.mem_used) for gpu in gpus)
    total = sum(max(0.0, gpu.mem_total) for gpu in gpus)
    available = max(0.0, total - used)
    return used, available, total


def gpu_summary(gpus: List[GpuRow]) -> Tuple[float, float, float, float, float, float]:
    used, available, total = vram_summary(gpus)
    util = sum(max(0.0, gpu.util) for gpu in gpus) / len(gpus) if gpus else 0.0
    power = sum(max(0.0, gpu.power) for gpu in gpus)
    temp = sum(max(0.0, gpu.temp) for gpu in gpus) / len(gpus) if gpus else 0.0
    return util, used, available, total, power, temp


def parse_gpus() -> List[GpuRow]:
    query = (
        "index,name,utilization.gpu,memory.used,memory.total,"
        "power.draw,temperature.gpu,pcie.link.gen.current,pcie.link.width.current"
    )
    out = run_cmd(
        [
            "nvidia-smi",
            f"--query-gpu={query}",
            "--format=csv,noheader,nounits",
        ],
        timeout=2.0,
    )
    rows = []
    for line in out.splitlines():
        parts = [p.strip() for p in line.split(",")]
        if len(parts) < 9:
            continue
        if not parts[0].isdigit():
            continue
        rows.append(
            GpuRow(
                index=parts[0],
                name=parts[1],
                util=parse_num(parts[2]),
                mem_used=parse_num(parts[3]),
                mem_total=parse_num(parts[4]),
                power=parse_num(parts[5]),
                temp=parse_num(parts[6]),
                gen=parts[7],
                width=parts[8],
            )
        )
    return rows


def telemetry_row(event: dict) -> Optional[Tuple[str, str]]:
    payload = event.get("payload") if isinstance(event, dict) else {}
    if not isinstance(payload, dict):
        payload = {}
    ev_type = str(event.get("type") or "event")
    if ev_type == "request_started":
        method = payload.get("method", "")
        path = payload.get("path", "")
        if str(path).startswith("/qz/telemetry"):
            return None
        return ("request", f"{method} {path}".strip())
    if ev_type == "deprecated_endpoint":
        path = payload.get("path", "")
        replacement = payload.get("replacement", "")
        return ("deprecated", f"{path} -> {replacement}".strip(" ->"))
    if ev_type == "request_completed":
        path = payload.get("path", "")
        status = payload.get("status", "")
        elapsed = payload.get("elapsed_ms")
        usage = payload.get("usage") if isinstance(payload.get("usage"), dict) else {}
        total_tokens = usage.get("total_tokens") or usage.get("output_tokens") or 0
        msg = f"{path}".strip()
        if status:
            msg += f" {status}"
        if elapsed:
            try:
                msg += f" {float(elapsed):.0f}ms"
            except Exception:
                pass
        if total_tokens:
            msg += f" {total_tokens}t"
        return ("request", msg.strip())
    if ev_type == "throughput_sample":
        path = payload.get("path", "")
        prompt_rate = payload.get("prompt_rate")
        gen_rate = payload.get("gen_rate")
        total_rate = payload.get("total_rate")
        msg = f"{path}".strip()
        parts = []
        if prompt_rate:
            parts.append(f"prompt={human_si(prompt_rate, '/s', precision=2)}")
        if gen_rate:
            parts.append(f"gen={human_si(gen_rate, '/s', precision=2)}")
        if total_rate:
            parts.append(f"total={human_si(total_rate, '/s', precision=2)}")
        if parts:
            msg = f"{msg} {' '.join(parts)}".strip()
        return ("throughput", msg.strip())
    if ev_type == "request_failed":
        path = payload.get("path", "")
        error = payload.get("error", "")
        return ("error", f"{path} {error}".strip())
    if ev_type == "status_snapshot":
        selected = payload.get("selected_key") or payload.get("selected") or ""
        load_state = payload.get("load_state") or ""
        ready = "ready" if payload.get("ready") else "not ready"
        parts = [ready]
        if selected:
            parts.append(str(selected))
        if load_state:
            parts.append(str(load_state))
        return ("status", " ".join(parts).strip())
    if ev_type in {"model_selected", "model_load_started", "model_load_pending", "model_load_ready", "model_load_failed"}:
        requested = payload.get("requested") or payload.get("model") or ""
        selected = payload.get("selected") or payload.get("backend_id") or ""
        parts = [ev_type.replace("_", " ")]
        if requested or selected:
            parts.append(f"{requested}->{selected}".strip("->"))
        if ev_type.endswith("failed") and payload.get("error"):
            parts.append(str(payload.get("error")))
        return ("model", " ".join(part for part in parts if part).strip())
    if ev_type in {"tool_call_started", "tool_call_completed"}:
        tool = payload.get("tool") or payload.get("action") or ""
        status = payload.get("status") or ""
        result_count = payload.get("result_count")
        msg = f"{ev_type.replace('_', ' ')} {tool}".strip()
        if status:
            msg += f" {status}"
        if result_count is not None:
            msg += f" {result_count}"
        return ("tool", msg.strip())
    if ev_type in {"web_search_route", "upstream_request"}:
        return ("web", ev_type.replace("_", " "))
    if ev_type in {"stream_started", "stream_completed", "stream_failed"}:
        return ("stream", ev_type.replace("_", " "))
    if ev_type == "sse_event":
        sse_type = str(payload.get("event_type") or "")
        if sse_type.endswith(".delta"):
            return ("stream", sse_type)
        if sse_type in ("response.created", "response.completed"):
            return ("stream", sse_type.rsplit(".", 1)[-1])
    return None


def _apply_request_completed_telemetry(rates: Rates, payload: dict):
    if not isinstance(payload, dict):
        return rates

    elapsed = payload.get("elapsed_ms")
    usage = payload.get("usage") if isinstance(payload.get("usage"), dict) else {}
    prompt_ms = payload.get("prompt_ms")
    gen_ms = payload.get("gen_ms")
    try:
        prompt_tokens = int(usage.get("input_tokens") or 0)
    except Exception:
        prompt_tokens = 0
    try:
        gen_tokens = int(usage.get("output_tokens") or 0)
    except Exception:
        gen_tokens = 0
    try:
        total_tokens = int(usage.get("total_tokens") or usage.get("output_tokens") or 0)
    except Exception:
        total_tokens = 0
    if prompt_tokens > 0 and isinstance(prompt_ms, (int, float)) and prompt_ms > 0:
        try:
            prompt_rate = prompt_tokens * 1000.0 / float(prompt_ms)
            rates.prompt_ms = max(rates.prompt_ms, float(prompt_ms))
            rates.prompt_tokens = max(rates.prompt_tokens, prompt_tokens)
            rates.prompt_latest = max(rates.prompt_latest, prompt_rate)
            rates.prompt_max = max(rates.prompt_max, prompt_rate)
        except Exception:
            pass
    if gen_tokens > 0 and isinstance(gen_ms, (int, float)) and gen_ms > 0:
        try:
            gen_rate = gen_tokens * 1000.0 / float(gen_ms)
            rates.gen_ms = max(rates.gen_ms, float(gen_ms))
            rates.gen_tokens = max(rates.gen_tokens, gen_tokens)
            rates.gen_latest = max(rates.gen_latest, gen_rate)
            rates.gen_max = max(rates.gen_max, gen_rate)
        except Exception:
            pass
    if elapsed:
        try:
            elapsed = float(elapsed)
            rates.total_ms = max(rates.total_ms, elapsed)
            rates.total_tokens = max(rates.total_tokens, total_tokens)
            if elapsed > 0 and total_tokens > 0:
                latest_rate = total_tokens * 1000.0 / elapsed
                rates.total_latest = max(rates.total_latest, latest_rate)
                rates.total_max = max(rates.total_max, latest_rate)
        except Exception:
            pass
    return rates


def _apply_throughput_sample_telemetry(rates: Rates, payload: dict):
    if not isinstance(payload, dict):
        return rates

    try:
        prompt_rate = float(payload.get("prompt_rate") or 0.0)
    except Exception:
        prompt_rate = 0.0
    try:
        gen_rate = float(payload.get("gen_rate") or 0.0)
    except Exception:
        gen_rate = 0.0
    try:
        total_rate = float(payload.get("total_rate") or 0.0)
    except Exception:
        total_rate = 0.0

    try:
        prompt_tokens = int(payload.get("prompt_tokens") or 0)
    except Exception:
        prompt_tokens = 0
    try:
        gen_tokens = int(payload.get("gen_tokens") or 0)
    except Exception:
        gen_tokens = 0
    try:
        total_tokens = int(payload.get("total_tokens") or 0)
    except Exception:
        total_tokens = 0

    prompt_ms = payload.get("prompt_ms")
    gen_ms = payload.get("gen_ms")
    elapsed_ms = payload.get("elapsed_ms")

    if prompt_rate > 0:
        rates.prompt_latest = max(rates.prompt_latest, prompt_rate)
        rates.prompt_max = max(rates.prompt_max, prompt_rate)
    if gen_rate > 0:
        rates.gen_latest = max(rates.gen_latest, gen_rate)
        rates.gen_max = max(rates.gen_max, gen_rate)
    if total_rate > 0:
        rates.total_latest = max(rates.total_latest, total_rate)
        rates.total_max = max(rates.total_max, total_rate)
    if prompt_tokens > 0:
        rates.prompt_tokens = max(rates.prompt_tokens, prompt_tokens)
    if gen_tokens > 0:
        rates.gen_tokens = max(rates.gen_tokens, gen_tokens)
    if total_tokens > 0:
        rates.total_tokens = max(rates.total_tokens, total_tokens)
    if isinstance(prompt_ms, (int, float)) and prompt_ms > 0:
        rates.prompt_ms = max(rates.prompt_ms, float(prompt_ms))
    if isinstance(gen_ms, (int, float)) and gen_ms > 0:
        rates.gen_ms = max(rates.gen_ms, float(gen_ms))
    if isinstance(elapsed_ms, (int, float)) and elapsed_ms > 0:
        rates.total_ms = max(rates.total_ms, float(elapsed_ms))
    return rates


def merge_telemetry(rates: Rates, telemetry: Optional[dict]) -> Rates:
    if not isinstance(telemetry, dict):
        return rates
    state = telemetry.get("state") or {}
    counters = state.get("counters") or {}
    try:
        rates.requests = max(rates.requests, int(counters.get("request_started") or 0))
    except Exception:
        pass

    latest_throughput = state.get("latest_throughput") if isinstance(state.get("latest_throughput"), dict) else None
    if latest_throughput:
        _apply_throughput_sample_telemetry(rates, latest_throughput.get("payload") if isinstance(latest_throughput.get("payload"), dict) else latest_throughput)

    rows = list(rates.recent or [])
    for event in telemetry.get("events") or []:
        row = telemetry_row(event)
        if row:
            rows.append(row)
        if event.get("type") == "throughput_sample":
            payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
            _apply_throughput_sample_telemetry(rates, payload)
        elif event.get("type") == "request_completed":
            payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
            _apply_request_completed_telemetry(rates, payload)
    rates.recent = rows[-9:]
    return rates


def latest_benchmark() -> Optional[BenchmarkSummary]:
    path = os.path.join(os.environ.get("QZ_VAR_DIR", "var"), "benchmarks", "latest-summary.json")
    try:
        with open(path, "r", encoding="utf-8") as handle:
            data = json.load(handle)
    except Exception:
        return None

    aggregate = data.get("aggregate")
    if not isinstance(aggregate, dict) or not aggregate:
        return None

    best_profile = ""
    best_row = None
    for profile, row in aggregate.items():
        if not isinstance(row, dict):
            continue
        cases = int(row.get("cases") or 0)
        if cases <= 0:
            continue
        ratio = row.get("avg_input_ratio")
        if ratio is None:
            ratio = row.get("avg_output_ratio")
        if ratio is None:
            continue
        best_ratio = best_row.get("avg_input_ratio") if best_row else None
        if best_ratio is None and best_row:
            best_ratio = best_row.get("avg_output_ratio", 9999)
        if best_row is None or float(ratio) < float(best_ratio):
            best_profile = profile
            best_row = row

    if best_row is None:
        return None

    return BenchmarkSummary(
        run_id=str(data.get("run_id", "")),
        baseline=str(data.get("baseline_profile", "")),
        profiles=len(data.get("profiles") or []),
        cases=int(data.get("case_count") or 0),
        prompt_count=int(data.get("prompt_count") or 0),
        best_profile=best_profile,
        best_input_ratio=float(best_row.get("avg_input_ratio", best_row.get("avg_output_ratio")) or 0.0),
        best_input_savings=float(best_row.get("avg_input_savings", best_row.get("avg_output_savings")) or 0.0),
        best_instructions_ratio=float(best_row.get("avg_instructions_ratio") or 0.0),
        best_final_ratio=float(best_row.get("avg_final_ratio") or 0.0),
        best_total_ratio=float(best_row.get("avg_total_ratio") or 0.0),
        best_wall_ratio=float(best_row.get("avg_wall_ratio") or 0.0),
    )


def clip(text: str, width: int) -> str:
    text = str(text)
    if width <= 0:
        return ""
    if len(text) <= width:
        return text
    if width == 1:
        return "…"
    return text[: width - 1] + "…"


class UI:
    def __init__(self, stdscr, interval: float):
        self.stdscr = stdscr
        self.interval = interval
        self.running = True
        self.setup_colours()

    def setup_colours(self):
        curses.start_color()
        curses.use_default_colors()
        pairs = [
            (1, curses.COLOR_GREEN),
            (2, curses.COLOR_YELLOW),
            (3, curses.COLOR_RED),
            (4, curses.COLOR_CYAN),
            (5, curses.COLOR_BLUE),
            (6, curses.COLOR_MAGENTA),
            (7, curses.COLOR_WHITE),
        ]
        for pair, colour in pairs:
            try:
                curses.init_pair(pair, colour, -1)
            except Exception:
                pass

        self.green = curses.color_pair(1)
        self.yellow = curses.color_pair(2)
        self.red = curses.color_pair(3)
        self.cyan = curses.color_pair(4)
        self.blue = curses.color_pair(5)
        self.magenta = curses.color_pair(6)
        self.white = curses.color_pair(7)
        self.bold = curses.A_BOLD
        self.dim = curses.A_DIM

    def colour_for_pct(self, pct: float):
        if pct >= 92:
            return self.red | self.bold
        if pct >= 82:
            return self.yellow | self.bold
        return self.green | self.bold

    def colour_for_util(self, util: float):
        if util >= 70:
            return self.red | self.bold
        if util >= 40:
            return self.yellow | self.bold
        return self.green | self.bold

    def add(self, y: int, x: int, text: str, attr=0):
        h, w = self.stdscr.getmaxyx()
        if y < 0 or y >= h or x >= w:
            return
        room = max(0, w - x - 1)
        try:
            self.stdscr.addstr(y, x, clip(text, room), attr)
        except curses.error:
            pass

    def box(self, y: int, x: int, h: int, w: int, title: str):
        max_h, max_w = self.stdscr.getmaxyx()
        if y >= max_h or x >= max_w:
            return
        h = min(h, max_h - y)
        w = min(w, max_w - x)
        if h < 3 or w < 8:
            return

        top = "┌" + "─" * (w - 2) + "┐"
        mid = "│" + " " * (w - 2) + "│"
        bot = "└" + "─" * (w - 2) + "┘"

        self.add(y, x, top, self.dim)
        for row in range(1, h - 1):
            self.add(y + row, x, mid, self.dim)
        self.add(y + h - 1, x, bot, self.dim)

        label = f" {title} "
        if len(label) < w - 4:
            self.add(y, x + 2, label, self.cyan | self.bold)

    def bar(self, used: float, total: float, width: int) -> Tuple[str, float]:
        if total <= 0:
            total = 1.0
        pct = used / total * 100.0
        filled = int((pct / 100.0) * width + 0.5)
        filled = max(0, min(width, filled))
        return "█" * filled + "░" * (width - filled), pct

    def draw_status_tile(self, y: int, x: int, label: str, ok: bool) -> int:
        light_attr = self.green | self.bold if ok else self.red | self.bold
        tile_attr = self.green if ok else self.red | self.bold
        text = f"╭─ {label} ● ─╮"
        light_x = x + len(f"╭─ {label} ")
        self.add(y, x, text, tile_attr)
        self.add(y, light_x, "●", light_attr)
        return len(text)

    def draw_status_bar(self, y: int, x: int, backend_ok: bool, proxy_ok: bool):
        cursor = x
        cursor += self.draw_status_tile(y, cursor, "BACKEND", backend_ok) + 2
        self.draw_status_tile(y, cursor, "PROXY", proxy_ok)

    def draw_header(self, backend_ok: bool, proxy_ok: bool, gpus: Optional[List[GpuRow]] = None):
        h, w = self.stdscr.getmaxyx()
        ts = time.strftime("%Y-%m-%d %H:%M:%S")
        self.add(0, 0, " QZ-TOP ", self.cyan | self.bold)
        self.add(0, 9, ts, self.bold)

        bx = 31
        self.add(0, bx, f"refresh={self.interval:g}s", self.dim)
        if gpus:
            used, available, total = vram_summary(gpus)
            self.add(
                0,
                bx + 23,
                f"vram={human_bytes_from_mib(used, compact=True)}/{human_bytes_from_mib(available, compact=True)}/{human_bytes_from_mib(total, compact=True)}",
                self.dim,
            )
        self.draw_status_bar(1, 1, backend_ok, proxy_ok)
        self.add(2, 0, "─" * max(1, w - 1), self.dim)

    def draw_profile(self, y: int, x: int, h: int, w: int, model_status: ModelStatus):
        self.box(y, x, h, w, "PROFILE")
        labels = ["CTX", "NP", "SPLIT", "BATCH", "UBATCH", "CACHE", "REUSE", "KV"]
        values = [
            os.environ.get("QZ_CONTEXT", "?"),
            os.environ.get("QZ_PARALLEL", "?"),
            os.environ.get("QZ_TENSOR_SPLIT", "?"),
            os.environ.get("QZ_BATCH", "?"),
            os.environ.get("QZ_UBATCH", "?"),
            human_bytes_from_mib(parse_num(os.environ.get("QZ_CACHE_RAM", "0"))),
            os.environ.get("QZ_CACHE_REUSE", "?"),
            os.environ.get("QZ_KV_KEY", "?") + "/" + os.environ.get("QZ_KV_VALUE", "?"),
        ]
        widths = [10, 5, 8, 8, 8, 9, 8, 16]

        cx = x + 2
        for label, width in zip(labels, widths):
            self.add(y + 1, cx, f"{label:<{width}}", self.dim | self.bold)
            cx += width + 1

        cx = x + 2
        for value, width in zip(values, widths):
            self.add(y + 2, cx, f"{clip(value, width):<{width}}", self.white)
            cx += width + 1

        loaded = model_status.loaded or "none"
        loaded_suffix = f" ({model_status.loaded_count})" if model_status.loaded_count > 1 else ""
        state = model_status.selected_state or model_status.load_state or "unknown"
        state_attr = self.green | self.bold if model_status.ready else self.yellow | self.bold
        if model_status.error:
            state_attr = self.red | self.bold
        self.add(y + 3, x + 2, "MODEL", self.dim | self.bold)
        self.add(y + 4, x + 2, "SELECTED", self.dim | self.bold)
        self.add(y + 4, x + 12, clip(model_status.selected or "?", w - 14), self.white)
        self.add(y + 5, x + 2, "LOADED", self.dim | self.bold)
        self.add(y + 5, x + 12, clip(f"{loaded}{loaded_suffix}", w - 14), self.white)
        self.add(y + 6, x + 2, "STATE", self.dim | self.bold)
        state_text = state
        if model_status.error:
            state_text += f" error={model_status.error}"
        self.add(y + 6, x + 12, clip(state_text, w - 14), state_attr)

    def draw_container(self, y: int, x: int, h: int, w: int):
        self.box(y, x, h, w, "CONTAINER")
        self.add(y + 1, x + 2, f"{'NAME':<16} {'STATUS':<27} PORTS", self.dim | self.bold)
        out = docker(
            [
                "ps",
                "-a",
                "--filter",
                f"name=^/{os.environ.get('QZ_CONTAINER', 'qwen36turbo')}$",
                "--format={{.Names}}|{{.Status}}|{{.Ports}}",
            ],
            timeout=2.0,
        )
        line = out.splitlines()[0] if out.splitlines() else "no container found||"
        parts = line.split("|")
        if len(parts) >= 3:
            name, status, ports = parts[0], parts[1], parts[2]
            attr = self.green if status.startswith("Up") else self.red | self.bold
            self.add(y + 2, x + 2, f"{clip(name, 16):<16} ", self.white)
            self.add(y + 2, x + 19, f"{clip(status, 27):<27}", attr)
            self.add(y + 2, x + 47, clip(ports, w - 50), self.white)
        else:
            self.add(y + 2, x + 2, clip(line, w - 4), self.red | self.bold)

    def draw_gpu(self, y: int, x: int, h: int, w: int, gpus: List[GpuRow]):
        self.box(y, x, h, w, "GPU")
        self.add(y + 1, x + 2, f"{'ID':<5} {'NAME':<27} {'UTIL':>5}  {'MODEL USE':>11} {'AVAILABLE':>11} {'TOTAL VRAM':>11} {'POWER':>8} {'TEMP':>6} {'PCIE':>8}", self.dim | self.bold)
        rows = gpus[: max(0, h - 4)]
        for i, gpu in enumerate(rows):
            row = y + 2 + i
            name = clip(gpu.name, 27)
            used = human_bytes_from_mib(gpu.mem_used)
            available = human_bytes_from_mib(max(0.0, gpu.mem_total - gpu.mem_used))
            total = human_bytes_from_mib(gpu.mem_total)
            row_text = (
                f"GPU{gpu.index:<2} {name:<27} {gpu.util:>4.0f}%  "
                f"{used:>11} {available:>11} {total:>11} "
                f"{gpu.power:>6.1f}W {gpu.temp:>5.0f}C g{gpu.gen}x{gpu.width}"
            )
            self.add(row, x + 2, row_text, self.colour_for_util(gpu.util))
        if gpus and len(rows) < h - 3:
            util, used, available, total, power, temp = gpu_summary(gpus)
            row = y + 2 + len(rows)
            total_text = (
                f"{'TOTAL':<5} {'':<27} {util:>4.0f}%  "
                f"{human_bytes_from_mib(used):>11} {human_bytes_from_mib(available):>11} {human_bytes_from_mib(total):>11} "
                f"{power:>6.1f}W {temp:>5.0f}C {'-':>8}"
            )
            self.add(row, x + 2, total_text, self.cyan | self.bold)

    def draw_throughput(self, y: int, x: int, h: int, w: int, rates: Rates):
        self.box(y, x, h, w, "LIVE THROUGHPUT")
        self.add(y + 1, x + 2, f"{'METRIC':<12} {'LATEST':>10} {'MAX':>10} {'TOKENS':>10} {'TIME':>9}", self.dim | self.bold)

        rows = [
            ("prompt", rates.prompt_latest, rates.prompt_max, rates.prompt_tokens, rates.prompt_ms),
            ("generate", rates.gen_latest, rates.gen_max, rates.gen_tokens, rates.gen_ms),
            ("total", rates.total_latest, rates.total_max, rates.total_tokens, rates.total_ms),
        ]
        for idx, (name, latest, max_rate, tokens, ms) in enumerate(rows):
            row = y + 2 + idx
            attr = self.green | self.bold if latest > 0 else self.dim
            row_text = (
                f"{name:<12} "
                f"{human_si(latest, '/s', precision=2):>10} "
                f"{human_si(max_rate, '/s', precision=2):>10} "
                f"{human_si(tokens, precision=1):>10} "
                f"{human_duration_ms(ms):>9}"
            )
            self.add(row, x + 2, row_text, attr)

        self.add(
            y + 6,
            x + 2,
            f"requests={human_si(rates.requests, precision=1):<5} checkpoints={human_si(rates.checkpoints, precision=1):<5} restores={human_si(rates.restores, precision=1):<5} CUDA_OOM=",
            self.white,
        )
        oom_attr = self.green | self.bold if rates.oom == 0 else self.red | self.bold
        self.add(y + 6, x + 60, human_si(rates.oom, precision=1), oom_attr)

    def draw_benchmark(self, y: int, x: int, h: int, w: int, benchmark: Optional[BenchmarkSummary]):
        if benchmark is None:
            return
        self.box(y, x, h, w, "BENCHMARK")
        line1 = (
            f"run={clip(benchmark.run_id, 16)} base={benchmark.baseline} "
            f"prompts={benchmark.prompt_count} cases={benchmark.cases} profiles={benchmark.profiles}"
        )
        line2 = (
            f"best={benchmark.best_profile} input={benchmark.best_input_ratio:.2f} "
            f"save={benchmark.best_input_savings * 100:.0f}% instr={benchmark.best_instructions_ratio:.2f} "
            f"final={benchmark.best_final_ratio:.2f} total={benchmark.best_total_ratio:.2f} wall={benchmark.best_wall_ratio:.2f}"
        )
        self.add(y + 1, x + 2, clip(line1, w - 4), self.cyan | self.bold)
        self.add(y + 2, x + 2, clip(line2, w - 4), self.cyan | self.bold)

    def draw_recent(self, y: int, x: int, h: int, w: int, rates: Rates):
        self.box(y, x, h, w, "RECENT")
        self.add(y + 1, x + 2, f"{'TYPE':<11} MESSAGE", self.dim | self.bold)
        max_msg = max(10, w - 17)
        for idx, (kind, msg) in enumerate((rates.recent or [])[-(h - 3):]):
            row = y + 2 + idx
            attr = self.white
            if kind == "OOM":
                attr = self.red | self.bold
            elif kind in ("restore", "checkpoint"):
                attr = self.cyan
            elif kind in ("prompt", "gen", "total", "throughput"):
                attr = self.green
            self.add(row, x + 2, f"{kind:<11}", attr | self.bold)
            self.add(row, x + 14, clip(msg, max_msg), self.white)

    def draw(self):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()

        backend_ok = curl_health(
            os.environ.get("QZ_SERVER_HOST", "127.0.0.1"),
            os.environ.get("QZ_SERVER_PORT", "18084"),
        )
        proxy_ok = curl_health(
            os.environ.get("QZ_PROXY_HOST", "127.0.0.1"),
            os.environ.get("QZ_PROXY_PORT", "18180"),
        )
        gpus = parse_gpus()

        rates = Rates(recent=[])
        status = proxy_status() if proxy_ok else None
        model_status = model_status_from_proxy(status)
        if proxy_ok:
            rates = merge_telemetry(rates, telemetry_recent())
        benchmark = latest_benchmark()

        self.draw_header(backend_ok, proxy_ok, gpus)

        if h < 25 or w < 100:
            self.add(4, 2, "Terminal too small. Need roughly 100x25.", self.red | self.bold)
            self.stdscr.refresh()
            return

        full_w = w - 2
        self.draw_profile(3, 0, 8, full_w, model_status)
        self.draw_container(11, 0, 5, full_w)
        self.draw_gpu(16, 0, 5 + min(2, len(gpus)), full_w, gpus)
        throughput_y = 21 + min(2, len(gpus))
        self.draw_throughput(throughput_y, 0, 9, full_w, rates)
        benchmark_h = 5 if benchmark is not None else 0
        if benchmark is not None:
            self.draw_benchmark(throughput_y + 9, 0, 5, full_w, benchmark)

        recent_y = throughput_y + 9 + benchmark_h
        recent_h = max(6, h - recent_y - 2)
        self.draw_recent(recent_y, 0, recent_h, full_w, rates)

        self.add(h - 1, 0, " q quit  Ctrl-C quit ", self.dim | self.bold)
        self.stdscr.refresh()

    def loop(self):
        self.stdscr.nodelay(True)
        curses.curs_set(0)
        while self.running:
            self.draw()
            deadline = time.time() + self.interval
            while time.time() < deadline:
                try:
                    key = self.stdscr.getch()
                except KeyboardInterrupt:
                    return
                if key in (ord("q"), ord("Q")):
                    return
                if key == 3:
                    return
                time.sleep(0.05)


def once():
    backend = curl_health(os.environ.get("QZ_SERVER_HOST", "127.0.0.1"), os.environ.get("QZ_SERVER_PORT", "18084"))
    proxy = curl_health(os.environ.get("QZ_PROXY_HOST", "127.0.0.1"), os.environ.get("QZ_PROXY_PORT", "18180"))
    gpus = parse_gpus()
    rates = Rates(recent=[])
    status = proxy_status() if proxy else None
    model_status = model_status_from_proxy(status)
    if proxy:
        rates = merge_telemetry(rates, telemetry_recent())
    benchmark = latest_benchmark()

    backend_light = "●" if backend else "○"
    proxy_light = "●" if proxy else "○"
    print(f"QZ-TOP {time.strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  ╭─ BACKEND {backend_light} ─╮  ╭─ PROXY {proxy_light} ─╮")
    print()
    print("PROFILE")
    print(f"  ctx={os.environ.get('QZ_CONTEXT', '?')} np={os.environ.get('QZ_PARALLEL', '?')} split={os.environ.get('QZ_TENSOR_SPLIT', '?')} batch={os.environ.get('QZ_BATCH', '?')} ubatch={os.environ.get('QZ_UBATCH', '?')} cache={human_bytes_from_mib(parse_num(os.environ.get('QZ_CACHE_RAM', '0')))} reuse={os.environ.get('QZ_CACHE_REUSE', '?')} kv={os.environ.get('QZ_KV_KEY', '?')}/{os.environ.get('QZ_KV_VALUE', '?')}")
    loaded_suffix = f" ({model_status.loaded_count})" if model_status.loaded_count > 1 else ""
    state = model_status.selected_state or model_status.load_state or "unknown"
    print(f"  selected : {model_status.selected or '?'}")
    print(f"  loaded   : {model_status.loaded or 'none'}{loaded_suffix}")
    print(f"  state    : {state}")
    if model_status.error:
        print(f"  error    : {model_status.error}")
    if gpus:
        used, available, total = vram_summary(gpus)
        print(f"  vram=model={human_bytes_from_mib(used)} available={human_bytes_from_mib(available)} total={human_bytes_from_mib(total)}")
    print()
    print("GPU")
    for gpu in gpus:
            avail = max(0.0, gpu.mem_total - gpu.mem_used)
            print(
                f"  GPU{gpu.index} {gpu.name:<26} util={gpu.util:3.0f}% "
                f"model={human_bytes_from_mib(gpu.mem_used)} avail={human_bytes_from_mib(avail)} total={human_bytes_from_mib(gpu.mem_total)} "
                f"pwr={gpu.power:.1f}W temp={gpu.temp:.0f}C PCIe=g{gpu.gen}x{gpu.width}"
            )
    if gpus:
        util, used, available, total, power, temp = gpu_summary(gpus)
        print(
            f"  TOTAL {'':<26} util={util:3.0f}% "
            f"model={human_bytes_from_mib(used)} avail={human_bytes_from_mib(available)} total={human_bytes_from_mib(total)} "
            f"pwr={power:.1f}W temp={temp:.0f}C PCIe=-"
        )
    print()
    print("LIVE THROUGHPUT")
    print(f"  prompt   latest={human_si(rates.prompt_latest, '/s', precision=2)} max={human_si(rates.prompt_max, '/s', precision=2)} tokens={human_si(rates.prompt_tokens, precision=1)} time={human_duration_ms(rates.prompt_ms)}")
    print(f"  generate latest={human_si(rates.gen_latest, '/s', precision=2)} max={human_si(rates.gen_max, '/s', precision=2)} tokens={human_si(rates.gen_tokens, precision=1)} time={human_duration_ms(rates.gen_ms)}")
    print(f"  total    latest={human_si(rates.total_latest, '/s', precision=2)} max={human_si(rates.total_max, '/s', precision=2)} tokens={human_si(rates.total_tokens, precision=1)} time={human_duration_ms(rates.total_ms)}")
    print(f"  requests={human_si(rates.requests, precision=1)} checkpoints={human_si(rates.checkpoints, precision=1)} restores={human_si(rates.restores, precision=1)} CUDA_OOM={human_si(rates.oom, precision=1)}")
    if benchmark is not None:
        print()
        print("BENCHMARK")
        print(f"  run={benchmark.run_id} baseline={benchmark.baseline} prompts={benchmark.prompt_count} cases={benchmark.cases} profiles={benchmark.profiles}")
        print(f"  best={benchmark.best_profile} input_ratio={benchmark.best_input_ratio:.2f} input_savings={benchmark.best_input_savings * 100:.0f}% instr_ratio={benchmark.best_instructions_ratio:.2f} final_ratio={benchmark.best_final_ratio:.2f} total_ratio={benchmark.best_total_ratio:.2f} wall_ratio={benchmark.best_wall_ratio:.2f}")


def main():
    parser = argparse.ArgumentParser(description="QuantZhai top-style monitor")
    parser.add_argument("--once", "-1", action="store_true", help="print one snapshot and exit")
    parser.add_argument("-i", "--interval", type=float, default=1.0, help="refresh interval in seconds")
    args = parser.parse_args()

    if args.once:
        once()
        return

    def handle_signal(signum, frame):
        raise KeyboardInterrupt

    signal.signal(signal.SIGINT, handle_signal)
    signal.signal(signal.SIGTERM, handle_signal)

    try:
        curses.wrapper(lambda stdscr: UI(stdscr, args.interval).loop())
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
