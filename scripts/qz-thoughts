#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -f "$SCRIPT_DIR/qz-env" ]]; then
  source "$SCRIPT_DIR/qz-env"
fi

set +e
set +u
set +o pipefail 2>/dev/null

python3 - "$@" <<'PY'
import argparse
import curses
import json
import os
import re
import shlex
import subprocess
import signal
import textwrap
import time
import urllib.request
from dataclasses import dataclass, field
from pathlib import Path
from typing import List, Optional, Tuple

MAX_LOG_LINES = 200


@dataclass
class ThoughtState:
    path: Path
    mtime: float = 0.0
    response_id: str = ""
    model: str = ""
    status: str = ""
    thought: str = ""
    answer: str = ""
    activity: List[Tuple[str, str]] = field(default_factory=list)
    backend: List[Tuple[str, str]] = field(default_factory=list)
    events: int = 0
    bytes_read: int = 0
    parse_error: str = ""
    backend_error: str = ""


def capture_path(name: str) -> Path:
    root = Path(os.environ.get("QZ_VAR_DIR", "var"))
    return root / "captures" / name


def proxy_base_url() -> str:
    host = os.environ.get("QZ_PROXY_HOST", "127.0.0.1")
    port = os.environ.get("QZ_PROXY_PORT", "18180")
    return f"http://{host}:{port}"


def fetch_json(url: str, timeout: float = 0.5) -> Optional[dict]:
    try:
        with urllib.request.urlopen(url, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except Exception:
        return None


def docker_cmd() -> List[str]:
    return shlex.split(os.environ.get("QZ_DOCKER_CMD", "docker"))


def read_backend_logs(lines: int) -> Tuple[List[Tuple[str, str]], str]:
    container = os.environ.get("QZ_CONTAINER", "qwen36turbo")
    lines = max(1, min(lines, MAX_LOG_LINES))
    try:
        out = subprocess.check_output(
            docker_cmd() + ["logs", f"--tail={lines}", container],
            stderr=subprocess.STDOUT,
            text=True,
            timeout=2.0,
        )
    except subprocess.CalledProcessError as exc:
        return [], (exc.output or str(exc)).strip()
    except Exception as exc:
        return [], str(exc)

    rows: List[Tuple[str, str]] = []
    for line in clean(out).splitlines():
        if "prompt processing progress" in line:
            rows.append(("prompt", re.sub(r"^.*?prompt processing progress,?\s*", "", line).strip()))
        elif "created context checkpoint" in line:
            rows.append(("checkpoint", re.sub(r"^.*?created context checkpoint", "created context checkpoint", line).strip()))
        elif "restored context checkpoint" in line:
            rows.append(("restore", re.sub(r"^.*?restored context checkpoint", "restored context checkpoint", line).strip()))
        elif "reasoning-budget:" in line:
            rows.append(("budget", line.strip()))
        elif "prompt eval time =" in line:
            rows.append(("prompt", line.strip()))
        elif re.search(r"^\s*eval time\s*=", line):
            rows.append(("generate", line.strip()))
        elif "total time =" in line:
            rows.append(("total", line.strip()))
        elif "done request:" in line:
            rows.append(("request", re.sub(r"^.*?done request:", "done request:", line).strip()))
        elif "processing task" in line:
            rows.append(("task", line.strip()))
    return rows[-24:], ""


def clean(text: str) -> str:
    text = (text or "").replace("\r", "\n")
    text = re.sub(r"\x1b\[[0-9;?]*[A-Za-z]", "", text)
    return text


def clip(text: str, width: int) -> str:
    if width <= 0:
        return ""
    text = clean(str(text)).replace("\n", " ")
    if len(text) <= width:
        return text
    return text[: max(0, width - 1)] + "…"


def parse_sse(raw: str, path: Path) -> ThoughtState:
    state = ThoughtState(path=path)
    try:
        stat = path.stat()
        state.mtime = stat.st_mtime
        state.bytes_read = stat.st_size
    except Exception:
        pass

    event_name = ""
    data_lines: List[str] = []

    def flush():
        nonlocal event_name, data_lines
        if not data_lines:
            event_name = ""
            return

        data = "\n".join(data_lines).strip()
        data_lines = []
        name = event_name
        event_name = ""
        if data == "[DONE]":
            state.status = "done"
            state.activity.append(("done", "stream completed"))
            return

        try:
            payload = json.loads(data)
        except Exception as exc:
            state.parse_error = f"{type(exc).__name__}: {exc}"
            return

        ev_type = payload.get("type") or name or "event"
        state.events += 1

        if ev_type == "response.created":
            response = payload.get("response") or {}
            state.response_id = response.get("id", state.response_id)
            state.model = response.get("model", state.model)
            state.status = response.get("status", state.status)
            state.activity.append(("created", f"{state.model} {state.response_id}"))
            return

        if ev_type in ("response.in_progress", "response.completed"):
            response = payload.get("response") or {}
            state.status = response.get("status", state.status)
            if response.get("model"):
                state.model = response["model"]
            if response.get("id"):
                state.response_id = response["id"]
            state.activity.append((ev_type.rsplit(".", 1)[-1], state.status or ev_type))
            return

        if ev_type == "response.output_item.added":
            item = payload.get("item") or {}
            label = item.get("type", "item")
            state.activity.append(("add", f"{label} {item.get('id', '')}".strip()))
            return

        if ev_type == "response.output_item.done":
            item = payload.get("item") or {}
            label = item.get("type", "item")
            state.activity.append(("done", f"{label} {item.get('status', '')}".strip()))
            return

        if ev_type in ("response.reasoning_text.delta", "response.reasoning_summary_text.delta"):
            state.thought += payload.get("delta") or ""
            state.activity.append(("thought", f"+{len(payload.get('delta') or '')} chars"))
            return

        if ev_type in ("response.reasoning_text.done", "response.reasoning_summary_text.done"):
            text = payload.get("text") or ""
            if text and len(text) > len(state.thought):
                state.thought = text
            state.activity.append(("thought", "done"))
            return

        if ev_type == "response.output_text.delta":
            state.answer += payload.get("delta") or ""
            state.activity.append(("answer", f"+{len(payload.get('delta') or '')} chars"))
            return

        if ev_type == "response.output_text.done":
            text = payload.get("text") or ""
            if text and len(text) > len(state.answer):
                state.answer = text
            state.activity.append(("answer", "done"))
            return

        if ev_type == "response.function_call_arguments.delta":
            state.activity.append(("tool", clip(payload.get("delta", ""), 80)))
            return

        state.activity.append(("event", ev_type))

    for line in raw.splitlines():
        if not line.strip():
            flush()
            continue
        if line.startswith("event:"):
            event_name = line.split(":", 1)[1].strip()
        elif line.startswith("data:"):
            data_lines.append(line.split(":", 1)[1].lstrip())

    flush()
    state.activity = state.activity[-40:]
    return state


def load_state(path: Path) -> ThoughtState:
    if not path.exists():
        state = ThoughtState(path=path)
        state.parse_error = f"missing: {path}"
        return state
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
    except Exception as exc:
        state = ThoughtState(path=path)
        state.parse_error = f"{type(exc).__name__}: {exc}"
        return state
    return parse_sse(raw, path)


def load_telemetry_state(limit: int = 200) -> Optional[ThoughtState]:
    data = fetch_json(f"{proxy_base_url()}/qz/telemetry/recent?limit={limit}")
    if not isinstance(data, dict):
        return None

    raw_parts: List[str] = []
    prefix_rows: List[Tuple[str, str]] = []
    latest_ts = 0.0
    for event in data.get("events") or []:
        if not isinstance(event, dict):
            continue
        try:
            latest_ts = max(latest_ts, float(event.get("ts") or 0.0))
        except Exception:
            pass
        ev_type = event.get("type")
        payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
        if ev_type == "sse_event":
            event_type = payload.get("event_type") or "event"
            sse_payload = payload.get("payload") if isinstance(payload.get("payload"), dict) else {}
            raw_parts.append(f"event: {event_type}\n")
            raw_parts.append("data: " + json.dumps(sse_payload, separators=(",", ":")) + "\n\n")
        elif ev_type == "request_started":
            path = payload.get("path", "")
            if not str(path).startswith("/qz/telemetry"):
                prefix_rows.append(("request", f"{payload.get('method', '')} {path}".strip()))
        elif ev_type == "deprecated_endpoint":
            prefix_rows.append(("deprecated", str(payload.get("path", ""))))

    if not raw_parts:
        return None

    raw = "".join(raw_parts)
    state = parse_sse(raw, Path("proxy-telemetry"))
    state.mtime = latest_ts or time.time()
    state.bytes_read = len(raw.encode("utf-8"))
    state.activity = (prefix_rows + state.activity)[-40:]
    return state


def load_live_state(path: Path) -> ThoughtState:
    state = load_telemetry_state()
    if state is not None:
        return state
    return load_state(path)


def wrap_lines(text: str, width: int, limit: int) -> List[str]:
    width = max(10, width)
    lines: List[str] = []
    for para in clean(text).splitlines() or [""]:
        if not para:
            lines.append("")
            continue
        lines.extend(textwrap.wrap(para, width=width, replace_whitespace=False, drop_whitespace=False) or [""])
    if len(lines) > limit:
        return lines[-limit:]
    return lines


class UI:
    def __init__(self, stdscr, path: Path, interval: float, log_lines: int):
        self.stdscr = stdscr
        self.path = path
        self.interval = interval
        self.log_lines = log_lines
        self.stdscr.nodelay(True)
        curses.curs_set(0)
        self.setup_colours()

    def setup_colours(self):
        curses.start_color()
        curses.use_default_colors()
        pairs = [
            (1, curses.COLOR_GREEN),
            (2, curses.COLOR_YELLOW),
            (3, curses.COLOR_RED),
            (4, curses.COLOR_CYAN),
            (5, curses.COLOR_BLUE),
            (6, curses.COLOR_MAGENTA),
            (7, curses.COLOR_WHITE),
        ]
        for pair, colour in pairs:
            try:
                curses.init_pair(pair, colour, -1)
            except Exception:
                pass

        self.green = curses.color_pair(1)
        self.yellow = curses.color_pair(2)
        self.red = curses.color_pair(3)
        self.cyan = curses.color_pair(4)
        self.blue = curses.color_pair(5)
        self.magenta = curses.color_pair(6)
        self.white = curses.color_pair(7)
        self.bold = curses.A_BOLD
        self.dim = curses.A_DIM

    def status_attr(self, status: str):
        if status == "completed":
            return self.green | self.bold
        if status in ("done", "in_progress"):
            return self.cyan | self.bold
        if status in ("failed", "error", "cancelled"):
            return self.red | self.bold
        return self.yellow | self.bold

    def kind_attr(self, kind: str):
        if kind in ("error", "failed", "OOM"):
            return self.red | self.bold
        if kind in ("thought", "reasoning", "budget"):
            return self.magenta | self.bold
        if kind in ("answer", "message", "completed", "done"):
            return self.green | self.bold
        if kind in ("prompt", "generate", "total", "request"):
            return self.cyan | self.bold
        if kind in ("restore", "checkpoint", "tool"):
            return self.yellow | self.bold
        return self.white

    def add(self, y: int, x: int, text: str, attr=0):
        h, w = self.stdscr.getmaxyx()
        if y < 0 or y >= h or x >= w:
            return
        try:
            self.stdscr.addstr(y, x, clip(text, max(0, w - x - 1)), attr)
        except curses.error:
            pass

    def box(self, y: int, x: int, h: int, w: int, title: str):
        max_h, max_w = self.stdscr.getmaxyx()
        if y >= max_h or x >= max_w:
            return
        h = min(h, max_h - y)
        w = min(w, max_w - x)
        if h < 3 or w < 8:
            return

        top = "┌" + "─" * (w - 2) + "┐"
        mid = "│" + " " * (w - 2) + "│"
        bot = "└" + "─" * (w - 2) + "┘"

        self.add(y, x, top, self.dim)
        for row in range(1, h - 1):
            self.add(y + row, x, mid, self.dim)
        self.add(y + h - 1, x, bot, self.dim)

        label = f" {title} "
        if len(label) < w - 4:
            self.add(y, x + 2, label, self.cyan | self.bold)

    def draw_text_panel(self, y: int, x: int, h: int, w: int, title: str, text: str, attr=0):
        self.box(y, x, h, w, title)
        lines = wrap_lines(text, max(10, w - 4), max(0, h - 2))
        if not text.strip():
            self.add(y + 1, x + 2, "(empty)", self.dim)
            return
        for i, line in enumerate(lines[-max(0, h - 2):]):
            self.add(y + 1 + i, x + 2, clip(line, w - 4), attr)

    def draw_activity(self, y: int, x: int, h: int, w: int, state: ThoughtState):
        self.box(y, x, h, w, "ACTIVITY")
        self.add(y + 1, x + 2, f"{'TYPE':<11} MESSAGE", self.dim | self.bold)
        rows = (state.backend + state.activity)[-max(0, h - 3):]
        for i, (kind, message) in enumerate(rows):
            row = y + 2 + i
            self.add(row, x + 2, f"{clip(kind, 10):<11}", self.kind_attr(kind))
            self.add(row, x + 14, clip(message, max(10, w - 16)), self.white)

    def draw_header(self, state: ThoughtState):
        h, w = self.stdscr.getmaxyx()
        age = max(0.0, time.time() - state.mtime) if state.mtime else 0.0
        status = state.status or "?"
        self.add(0, 0, " QZ-THOUGHTS ", self.cyan | self.bold)
        self.add(0, 14, time.strftime("%Y-%m-%d %H:%M:%S"), self.bold)
        self.add(0, 36, "status=", self.dim)
        self.add(0, 43, status, self.status_attr(status))
        self.add(0, 55, f"events={state.events}", self.dim)
        self.add(0, 68, f"age={age:.1f}s", self.yellow | self.bold if age > 30 else self.dim)
        self.add(0, 82, f"bytes={state.bytes_read}", self.dim)
        self.add(1, 0, "─" * max(1, w - 1), self.dim)

    def draw_meta(self, y: int, state: ThoughtState):
        _, w = self.stdscr.getmaxyx()
        path_text = str(state.path)
        home = str(Path.home())
        if path_text.startswith(home + "/"):
            path_text = "~/" + path_text[len(home) + 1 :]

        left = f"model={state.model or '?'}"
        mid = f"response={state.response_id or '?'}"
        right = f"source={path_text}"
        self.add(y, 0, clip(left, 34), self.white)
        self.add(y, 36, clip(mid, 48), self.dim)
        self.add(y, 86, clip(right, max(10, w - 87)), self.dim)

        warnings = []
        if state.parse_error:
            warnings.append(f"parse={state.parse_error}")
        if state.backend_error:
            warnings.append(f"backend={state.backend_error}")
        if warnings:
            self.add(y + 1, 0, clip("  ".join(warnings), w - 1), self.red | self.bold)

    def draw(self, state: ThoughtState):
        self.stdscr.erase()
        h, w = self.stdscr.getmaxyx()
        self.draw_header(state)

        if h < 22 or w < 100:
            self.add(3, 2, "Terminal too small. Need roughly 100x22.", self.red | self.bold)
            self.stdscr.refresh()
            return

        self.draw_meta(2, state)

        body_y = 4
        body_h = max(8, h - body_y - 2)
        full_w = max(98, w - 2)
        activity_w = min(62, max(40, full_w // 3))
        thought_w = max(36, full_w - activity_w - 1)
        answer_h = max(5, min(9, body_h // 4))
        thought_h = max(7, body_h - answer_h)

        self.draw_text_panel(body_y, 0, thought_h, thought_w, "THOUGHT", state.thought, self.white)
        self.draw_activity(body_y, thought_w + 1, thought_h, activity_w, state)
        self.draw_text_panel(body_y + thought_h, 0, answer_h, full_w, "ANSWER", state.answer, self.green | self.bold)
        self.add(h - 1, 0, " q quit  Ctrl-C quit ", self.dim | self.bold)
        self.stdscr.refresh()

    def loop(self):
        while True:
            state = load_live_state(self.path)
            state.backend, state.backend_error = read_backend_logs(self.log_lines)
            self.draw(state)
            deadline = time.time() + self.interval
            while time.time() < deadline:
                try:
                    key = self.stdscr.getch()
                except KeyboardInterrupt:
                    return
                if key in (ord("q"), ord("Q"), 3):
                    return
                time.sleep(0.05)


def print_once(path: Path, log_lines: int):
    state = load_live_state(path)
    state.backend, state.backend_error = read_backend_logs(log_lines)
    age = max(0.0, time.time() - state.mtime) if state.mtime else 0.0
    print(f"QZ-THOUGHTS {time.strftime('%Y-%m-%d %H:%M:%S')} status={state.status or '?'} events={state.events} age={age:.1f}s bytes={state.bytes_read}")
    print(f"source={state.path}")
    print(f"model={state.model or '?'} response={state.response_id or '?'}")
    if state.parse_error:
        print(f"error={state.parse_error}")
    if state.backend_error:
        print(f"backend_error={state.backend_error}")
    print()
    print("THOUGHT")
    print(state.thought.strip() or "(empty)")
    print()
    print("ANSWER")
    print(state.answer.strip() or "(empty)")
    print()
    print("ACTIVITY")
    for kind, message in state.backend:
        print(f"  {kind:<9} {message}")
    for kind, message in state.activity:
        print(f"  {kind:<9} {message}")


def main():
    parser = argparse.ArgumentParser(description="Monitor QuantZhai streamed reasoning/thought output")
    parser.add_argument("--once", "-1", action="store_true", help="print one snapshot and exit")
    parser.add_argument("-i", "--interval", type=float, default=0.5, help="refresh interval in seconds")
    parser.add_argument("-n", "--lines", type=int, default=120, help=f"backend log lines to scan, capped at {MAX_LOG_LINES}")
    parser.add_argument("--file", default=str(capture_path("latest-synthetic-sse.raw")), help="SSE capture file to monitor")
    args = parser.parse_args()
    args.lines = max(1, min(args.lines, MAX_LOG_LINES))

    path = Path(args.file)
    if args.once:
        print_once(path, args.lines)
        return

    def handle_signal(signum, frame):
        raise KeyboardInterrupt

    signal.signal(signal.SIGINT, handle_signal)
    signal.signal(signal.SIGTERM, handle_signal)

    try:
        curses.wrapper(lambda stdscr: UI(stdscr, path, args.interval, args.lines).loop())
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
PY
