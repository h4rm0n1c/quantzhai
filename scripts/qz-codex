#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/qz-codex-common"

case "${1:-}" in
  low|medium|high|max|caveman)
    printf 'qz-codex: profile argument %s is deprecated; select a model from the Codex model picker or pass Codex CLI arguments directly\n' "$1" >&2
    exit 64
    ;;
esac

qz_prepare_codex_home

QZ_CODEX_EXTRA_ARGS=()
if [[ -n "${QZ_CODEX_MODEL_PROVIDER:-}" ]]; then
  QZ_CODEX_EXTRA_ARGS+=(-c "model_provider=\"$QZ_CODEX_MODEL_PROVIDER\"")
fi

exec codex "${QZ_CODEX_EXTRA_ARGS[@]}" "$@"
