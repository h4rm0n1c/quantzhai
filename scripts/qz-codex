#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/qz-codex-common"

codex_subcommands=(
  exec review login logout mcp plugin mcp-server app-server completion sandbox
  debug apply resume fork cloud exec-server features help
)

is_codex_subcommand() {
  local arg="${1:-}"
  local cmd
  for cmd in "${codex_subcommands[@]}"; do
    [[ "$arg" == "$cmd" ]] && return 0
  done
  return 1
}

profile="high"
if [[ $# -gt 0 ]] && ! is_codex_subcommand "$1"; then
  profile="$1"
  shift
fi

qz_prepare_codex_home
qz_resolve_codex_profile "$profile"

loaded_model="$(qz_proxy_loaded_model)"
if [[ -n "$loaded_model" ]]; then
  QZ_CODEX_MODEL="$loaded_model"
fi

model_context_window="$(qz_codex_model_context_window "$QZ_CODEX_MODEL")"
if [[ -n "$model_context_window" ]]; then
  QZ_CODEX_EXTRA_ARGS+=(-c "model_context_window=$model_context_window")
fi

qz_sync_codex_model "$QZ_CODEX_MODEL"

exec codex "${QZ_CODEX_EXTRA_ARGS[@]}" -m "$QZ_CODEX_MODEL" "$@"
