#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/qz-env"

mkdir -p "$QZ_VAR_DIR/logs" "$QZ_VAR_DIR/run" "$QZ_VAR_DIR/captures"

pid_file="$QZ_VAR_DIR/run/qz-proxy.pid"

if [[ -f "$pid_file" ]]; then
  old_pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
    kill "$old_pid"
  fi
fi

pkill -f "[q]uantzhai_proxy.py" 2>/dev/null || true
pkill -f "[q]wen36turbo_proxy.py" 2>/dev/null || true

nohup python3 "$QZ_ROOT/proxy/quantzhai_proxy.py" \
  --listen "$QZ_PROXY_HOST" \
  --port "$QZ_PROXY_PORT" \
  --upstream "http://$QZ_SERVER_HOST:$QZ_SERVER_PORT" \
  --reasoning-stream-format summary \
  > "$QZ_VAR_DIR/logs/qz-proxy.log" 2>&1 &

echo "$!" > "$pid_file"
sleep 0.5
if ! kill -0 "$(cat "$pid_file")" 2>/dev/null; then
  echo "proxy failed to start; see $QZ_VAR_DIR/logs/qz-proxy.log" >&2
  exit 1
fi
printf 'proxy listening: http://%s:%s\n' "$QZ_PROXY_HOST" "$QZ_PROXY_PORT"
