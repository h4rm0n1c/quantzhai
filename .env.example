# QuantZhai local settings.
#
# Copy to .env and edit paths for your machine.

QZ_IMAGE=thetom-llama-cpp-turboquant:cuda-server
# If Docker needs sudo, simplest manual option is:
# QZ_DOCKER_CMD="sudo docker"
#
# For non-interactive Codex runs on sudo hosts, install the repo helper once:
# scripts/qz-install-sudo-helper
# Then use:
# QZ_DOCKER_CMD="sudo -n /usr/local/sbin/qz-docker-quantzhai"
QZ_DOCKER_CMD=docker
QZ_CONTAINER=qwen36turbo

QZ_BUILD_DIR=$HOME/turboquant-work
QZ_TQ_REPO=https://github.com/TheTom/llama-cpp-turboquant.git
QZ_TQ_BRANCH=feature/turboquant-kv-cache
QZ_CUDA_ARCH="70;86"

# Model files live under var/models by default. The proxy owns catalog
# selection now; set QZ_MODEL_KEY to pick a GGUF.
QZ_MODEL_DIR=$QZ_ROOT/var/models
QZ_MODEL_KEY=
QZ_MODEL_OVERRIDES=$QZ_ROOT/var/model-overrides.json
# QZSTATE=1
# QZ_CAPTURE_MODE=latest
# QZ_CAPTURE_MODE=off
# QZ_MONITOR_LOG_FALLBACK=1

QZ_SERVER_HOST=127.0.0.1
QZ_SERVER_PORT=18084
QZ_PROXY_HOST=127.0.0.1
QZ_PROXY_PORT=18180

QZ_CONTEXT=131072
QZ_PARALLEL=1
QZ_BATCH=4096
QZ_UBATCH=512
QZ_THREADS=12
QZ_THREAD_BATCH=12
QZ_TENSOR_SPLIT=9,17
QZ_MAIN_GPU=0
QZ_CACHE_RAM=8192
QZ_CACHE_REUSE=256
QZ_KV_KEY=q8_0
QZ_KV_VALUE=turbo3

# Optional local web search. Leave SEARXNG_BASE_URL empty to disable search.
SEARXNG_BASE_URL=
SEARXNG_TIMEOUT=15
SEARXNG_POLICY=$QZ_ROOT/docs/searxng-agent-policy-profiled.json
SEARXNG_CAPABILITIES=
